---
const items = [
  { title: "Furniture",          desc: "Chairs, sofas, tables, shelving — old or bulky, we haul it away." },
  { title: "Electronics",        desc: "E-waste recycling for monitors, computers, printers and more." },
  { title: "Appliances",         desc: "Refrigerators, washers, dryers, commercial equipment." },
  { title: "Mattresses",         desc: "Same-day mattress removal — we handle all the heavy lifting." },
  { title: "Hot Tubs",           desc: "Full disassembly and removal from any location on your property." },
  { title: "Yard Waste",         desc: "Wood piles, shrubs, leaves, soil — full outdoor cleanouts." },
  { title: "Miscellaneous",      desc: "Not sure it fits a category? Call us — we handle it all." },
  { title: "Full Space Cleanouts", desc: "Rooms, garages, offices, storage units — total clearouts." },
];

const icons: Record<string, string> = {
  "Furniture":            `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 11V8a2 2 0 012-2h14a2 2 0 012 2v3"/><path d="M3 11a2 2 0 00-2 2v1h22v-1a2 2 0 00-2-2H3z"/><path d="M5 17v2M19 17v2"/></svg>`,
  "Electronics":          `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="4" width="20" height="14" rx="2"/><path d="M8 20h8M12 18v2"/></svg>`,
  "Appliances":           `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="5" y="2" width="14" height="20" rx="2"/><circle cx="12" cy="14" r="3"/><path d="M9 6h1M13 6h2"/></svg>`,
  "Mattresses":           `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="8" width="20" height="10" rx="2"/><path d="M2 14h20M6 8V6M18 8V6"/></svg>`,
  "Hot Tubs":             `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 17h18v2a2 2 0 01-2 2H5a2 2 0 01-2-2v-2z"/><rect x="3" y="10" width="18" height="7" rx="1"/><path d="M7 10V8M12 10V6M17 10V8"/></svg>`,
  "Yard Waste":           `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 22V12"/><path d="M12 12C12 8 7 5 7 5s1 5 5 7"/><path d="M12 12c0-4 5-7 5-7s-1 5-5 7"/><path d="M5 22h14"/></svg>`,
  "Miscellaneous":        `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>`,
  "Full Space Cleanouts": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
};
---

<section class="services" id="services">
  <div class="container">

    <!-- Header -->
    <div class="tc services__header">
      <span class="eyebrow">What We Do</span>
      <div class="accent-line"></div>
      <h2 class="h2">Top-Notch Junk Hauling<br/>for Homes &amp; Businesses</h2>
      <p class="lead">
        Our crew handles any size job — from a single item to full property clearouts.
        We do all the heavy lifting so you don't have to.
      </p>
    </div>

    <!-- Service types -->
    <div class="service-types">
      <div class="service-type">
        <div class="service-type__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M1 3h4l2.68 13.39a2 2 0 001.98 1.61h9.72a2 2 0 001.98-1.61L23 6H6"/></svg>
        </div>
        <div>
          <h3>Full-Service Junk Removal</h3>
          <p>Free estimates · Same-day · Pay only for the space you use · Eco-friendly</p>
        </div>
      </div>
      <div class="service-type">
        <div class="service-type__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-4 0v2M8 7V5a2 2 0 00-4 0v2"/><path d="M12 12v4M10 14h4"/></svg>
        </div>
        <div>
          <h3>Any Size Job</h3>
          <p>Single item · Residential cleanouts · Commercial services</p>
        </div>
      </div>
      <div class="service-type">
        <div class="service-type__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
        </div>
        <div>
          <h3>Dumpster Bag Pickup</h3>
          <p>Any brand accepted · Fill at your pace · Easy online scheduling</p>
        </div>
      </div>
    </div>

    <!-- Items grid -->
    <div class="items-grid">
      {items.map((item) => (
        <div class="item-card">
          <div class="item-card__icon" set:html={icons[item.title]}></div>
          <h3 class="item-card__title">{item.title}</h3>
          <p class="item-card__desc">{item.desc}</p>
        </div>
      ))}
    </div>

    <!-- Dumpster CTA -->
    <div class="dumpster-cta">
      <div class="dumpster-cta__text">
        <span class="eyebrow" style="color:#fff;opacity:0.6;">Dumpster Bag Pickup</span>
        <h3>Fill It at Your Own Pace</h3>
        <p>We remove any brand of dumpster bag from anywhere on your property. Fill it at your pace, schedule online, and our crew will haul it away — fast and stress-free.</p>
        <a href="#contact" class="btn btn-primary">Schedule Pickup</a>
      </div>
      <ul class="dumpster-cta__list">
        <li>
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 10l4 4 7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Any brand bag accepted
        </li>
        <li>
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 10l4 4 7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Fill at your own pace
        </li>
        <li>
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 10l4 4 7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Easy online scheduling
        </li>
        <li>
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 10l4 4 7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Fast, professional pickup
        </li>
      </ul>
    </div>

  </div>
</section>

<style>
  .services { padding: 6rem 0; background: var(--ink-50); }
  .services__header { margin-bottom: 4rem; }
  .services__header .lead { margin: 0 auto; }
  .services__header .eyebrow { color: #000A1A; }

  /* Service types */
  .service-types {
    display: grid; grid-template-columns: repeat(3,1fr);
    gap: 1.25rem; margin-bottom: 3rem;
  }
  .service-type {
    display: flex; align-items: flex-start; gap: 1rem;
    background: var(--white); border: 1px solid var(--ink-200);
    border-radius: var(--r-lg); padding: 1.5rem;
    transition: all var(--ease);
  }
  .service-type:hover { border-color: #000A1A; box-shadow: var(--sh-md); }
  .service-type__icon {
    width: 42px; height: 42px; background: var(--red-sub);
    border-radius: var(--r); display: flex; align-items: center;
    justify-content: center; flex-shrink: 0;
  }
  .service-type__icon svg { width: 20px; height: 20px; stroke: #000A1A; }
  .service-type h3 { font-size: 0.9rem; font-weight: 700; color: var(--ink-900); margin-bottom: 0.3rem; }
  .service-type p  { font-size: 0.8rem; color: var(--ink-500); line-height: 1.55; }

  /* Items grid */
  .items-grid {
    display: grid; grid-template-columns: repeat(4,1fr);
    gap: 1rem; margin-bottom: 3rem;
  }
  .item-card {
    background: var(--white); border: 1px solid var(--ink-200);
    border-radius: var(--r-lg); padding: 1.5rem 1.25rem;
    transition: all var(--ease);
  }
  .item-card:hover { border-color: #000A1A; transform: translateY(-3px); box-shadow: var(--sh-md); }
  .item-card__icon { width: 40px; height: 40px; background: var(--red-sub); border-radius: var(--r); display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; }
  .item-card__icon svg { width: 20px; height: 20px; stroke: #000A1A; }
  .item-card__title { font-size: 0.88rem; font-weight: 700; color: var(--ink-900); margin-bottom: 0.4rem; }
  .item-card__desc  { font-size: 0.8rem; color: var(--ink-500); line-height: 1.55; }

  /* Dumpster CTA */
  .dumpster-cta {
    background: var(--ink-900); border-radius: var(--r-xl);
    padding: 3rem; display: grid; grid-template-columns: 1fr auto;
    gap: 3rem; align-items: center;
  }
  .dumpster-cta__text h3 { font-size: 1.5rem; font-weight: 800; color: #fff; margin-bottom: 0.85rem; letter-spacing: -0.02em; }
  .dumpster-cta__text p  { font-size: 0.9rem; color: rgba(255,255,255,0.6); line-height: 1.7; margin-bottom: 1.75rem; max-width: 480px; }
  .dumpster-cta__list { display: flex; flex-direction: column; gap: 0.75rem; min-width: 220px; }
  .dumpster-cta__list li { display: flex; align-items: center; gap: 0.6rem; font-size: 0.85rem; color: rgba(255,255,255,0.75); font-weight: 500; }
  .dumpster-cta__list svg { width: 16px; height: 16px; stroke: var(--red); flex-shrink: 0; }

  @media (max-width: 1024px) {
    .items-grid { grid-template-columns: repeat(3,1fr); }
    .service-types { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .services { padding: 4rem 0; }
    .items-grid { grid-template-columns: repeat(2,1fr); }
    .dumpster-cta { grid-template-columns: 1fr; padding: 2rem; gap: 2rem; }
  }
  @media (max-width: 480px) {
    .items-grid { grid-template-columns: 1fr; }
  }
</style>
