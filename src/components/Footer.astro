<style>
  .footer {
    background: var(--color-gray-900);
    color: var(--color-white);
  }

  .footer-main {
    padding: 4rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 3rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-logo-icon {
    font-size: 1.75rem;
    background: var(--color-primary);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-logo > div {
    display: flex;
    flex-direction: column;
  }

  .footer-logo-brand {
    font-size: 1.1rem;
    font-weight: 900;
    color: var(--color-white);
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .footer-logo-loc {
    font-size: 0.6rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
  }

  .footer-phone {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-white);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer-phone:hover {
    color: var(--color-primary);
  }

  .footer-address {
    font-style: normal;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.6;
  }

  .footer-socials {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .footer-social {
    width: 34px;
    height: 34px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: var(--border-radius);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.7);
    font-weight: 700;
    transition: all var(--transition);
