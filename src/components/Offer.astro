---

<section class="offer" id="offer">
  <div class="container">
    <div class="offer__card">

      <!-- Coupon side -->
      <div class="offer__coupon">
        <div class="offer__tag">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/>
            <line x1="7" y1="7" x2="7.01" y2="7" stroke-linecap="round" stroke-width="2.5"/>
          </svg>
          Special Offer
        </div>
        <div class="offer__amount">$20<span class="offer__off">OFF</span></div>
        <p class="offer__condition">when you book online</p>
        <div class="offer__divider">
          <span></span><span class="offer__divider-text">COUPON</span><span></span>
        </div>
        <p class="offer__expires">Valid through <strong>September 30, 2026</strong></p>
      </div>

      <!-- CTA side -->
      <div class="offer__cta">
        <h2>Save $20 — Book Online Today</h2>
        <p>
          Skip the call and schedule your junk removal online. Choose your date, pick a 2-hour window,
          and automatically save $20 on any size job. No promo code needed.
        </p>
        <ul class="offer__list">
          <li>
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M5 10l4 4 6-6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Any size job qualifies
          </li>
          <li>
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M5 10l4 4 6-6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            No promo code required
          </li>
          <li>
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M5 10l4 4 6-6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            One-time use per address
          </li>
        </ul>
        <div class="offer__actions">
          <a href="#contact" class="btn btn-white btn-lg">Book Online — Save $20</a>
          <a href="tel:+15612466352" class="btn btn-ghost" style="color:#fff; border-color:rgba(255,255,255,0.2);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.5 19.79 19.79 0 01.02 2.84 2 2 0 012 .67h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.49a16 16 0 006.29 6.29l1.1-1.1a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            Call Instead
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .offer { padding: 6rem 0; background: var(--white); }

  .offer__card {
    background: var(--ink-900);
    border-radius: var(--r-xl);
    display: grid; grid-template-columns: 320px 1fr;
    overflow: hidden;
  }

  /* Coupon */
  .offer__coupon {
    background: var(--red); padding: 3rem 2.5rem;
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; text-align: center; position: relative;
  }
  .offer__coupon::after {
    content: "";
    position: absolute; right: -20px; top: 0; bottom: 0;
    width: 40px;
    background: radial-gradient(circle at right, var(--ink-900) 14px, transparent 14px) 0 0 / 40px 32px;
  }

  .offer__tag {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; color: rgba(255,255,255,0.75); margin-bottom: 1.5rem;
  }
  .offer__tag svg { width: 14px; height: 14px; stroke: rgba(255,255,255,0.75); }

  .offer__amount {
    font-size: 5rem; font-weight: 900; color: #fff; line-height: 1;
    letter-spacing: -0.04em; display: flex; align-items: flex-start; gap: 0.15em;
  }
  .offer__off {
    font-size: 1.4rem; font-weight: 700; margin-top: 0.5rem;
    letter-spacing: 0.04em; opacity: 0.85;
  }
  .offer__condition { font-size: 0.82rem; color: rgba(255,255,255,0.7); margin-top: 0.5rem; }

  .offer__divider {
    display: flex; align-items: center; gap: 0.6rem;
    width: 100%; margin: 1.5rem 0 1rem;
  }
  .offer__divider span:not(.offer__divider-text) {
    flex: 1; height: 1px; background: rgba(255,255,255,0.25); border-style: dashed;
  }
  .offer__divider-text { font-size: 0.65rem; font-weight: 700; color: rgba(255,255,255,0.5); letter-spacing: 0.12em; white-space: nowrap; }
  .offer__expires { font-size: 0.78rem; color: rgba(255,255,255,0.6); }
  .offer__expires strong { color: rgba(255,255,255,0.9); }

  /* CTA */
  .offer__cta { padding: 3rem 3.5rem; }
  .offer__cta h2 { font-size: 1.6rem; font-weight: 800; color: #fff; letter-spacing: -0.025em; margin-bottom: 1rem; line-height: 1.2; }
  .offer__cta p  { font-size: 0.88rem; color: rgba(255,255,255,0.6); line-height: 1.7; margin-bottom: 1.75rem; max-width: 440px; }

  .offer__list { display: flex; flex-direction: column; gap: 0.65rem; margin-bottom: 2.25rem; }
  .offer__list li { display: flex; align-items: center; gap: 0.6rem; font-size: 0.85rem; color: rgba(255,255,255,0.75); font-weight: 500; }
  .offer__list svg { width: 18px; height: 18px; stroke: var(--red); flex-shrink: 0; }

  .offer__actions { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .offer__actions .btn { display: flex; align-items: center; gap: 0.5rem; }
  .offer__actions .btn svg { width: 16px; height: 16px; }

  @media (max-width: 900px) {
    .offer__card { grid-template-columns: 1fr; }
    .offer__coupon::after { display: none; }
    .offer__cta { padding: 2.5rem 2rem; }
  }
  @media (max-width: 768px) {
    .offer { padding: 4rem 0; }
    .offer__coupon { padding: 2.5rem 1.5rem; }
    .offer__amount { font-size: 4rem; }
  }
</style>
