  /* Aplica las traducciones a todos los elementos [data-i18n] */
  function applyTranslations(lang: string) {
    if (lang === "en") {
      // Restaurar textos originales guardados
      document.querySelectorAll("[data-i18n]").forEach((el) => {
        const orig = (el as HTMLElement).dataset.i18nOrig;
        if (orig !== undefined) {
          if (el.tagName === "INPUT" || el.tagName === "TEXTAREA") {
            (el as HTMLInputElement).placeholder = orig;
          } else {
            el.textContent = orig;
          }
        }
      });
      document.documentElement.lang = "en";
      return;
    }

    document.querySelectorAll("[data-i18n]").forEach((el) => {
      const key = (el as HTMLElement).dataset.i18n!;
      const translated = TRANSLATIONS[key]?.[lang];
      if (!translated) return;

      // Guardar original la primera vez
      if ((el as HTMLElement).dataset.i18nOrig === undefined) {
        if (el.tagName === "INPUT" || el.tagName === "TEXTAREA") {
          (el as HTMLElement).dataset.i18nOrig = (el as HTMLInputElement).placeholder;
        } else {
          (el as HTMLElement).dataset.i18nOrig = el.textContent ?? "";
        }
      }

      if (el.tagName === "INPUT" || el.tagName === "TEXTAREA") {
        (el as HTMLInputElement).placeholder = translated;
      } else {
        el.textContent = translated;
      }
    });

    document.documentElement.lang = lang.split("-")[0];
  }

  /* Restore active language on page load */
  (function () {
    const saved = localStorage.getItem("siteLang");
    if (saved && saved !== "en" && LANG_NAMES[saved]) {
      langLabel.textContent = LANG_NAMES[saved];
      applyTranslations(saved);
    }
  })();

  /* Toggle dropdown */
  langBtn.addEventListener("click", (e) => {
    e.stopPropagation();
    const isOpen = langBtn.getAttribute("aria-expanded") === "true";
    langBtn.setAttribute("aria-expanded", String(!isOpen));
    langDropdown.classList.toggle("is-open");
  });

  /* Close on outside click */
  document.addEventListener("click", () => {
    langBtn.setAttribute("aria-expanded", "false");
    langDropdown.classList.remove("is-open");
  });
  langDropdown.addEventListener("click", (e) => e.stopPropagation());

  /* Select language → aplica al instante sin redirigir */
  langDropdown.querySelectorAll("li[data-lang]").forEach((li) => {
    li.addEventListener("click", () => {
      const code = (li as HTMLElement).dataset.lang!;
      langBtn.setAttribute("aria-expanded", "false");
      langDropdown.classList.remove("is-open");
      langLabel.textContent = LANG_NAMES[code] ?? code;
      localStorage.setItem("siteLang", code);
      applyTranslations(code);
    });
  });
</script>

