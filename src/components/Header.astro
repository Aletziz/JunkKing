---
---
<header class="header" id="top">
  <div class="top-bar">
    <div class="container top-bar__inner">
      <a href="tel:+15614607921" class="top-bar__item">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M2 3.5A1.5 1.5 0 013.5 2h1.148a1 1 0 01.95.684l.93 2.8a1 1 0 01-.23 1.02L5.1 7.7a11.04 11.04 0 005.2 5.2l1.196-1.198a1 1 0 011.02-.23l2.8.93A1 1 0 0116 13.35v1.15A1.5 1.5 0 0114.5 16C7.596 16 2 10.404 2 3.5z"/></svg>
        (561) 460-7921
      </a>
      <span class="top-bar__item">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17.5s-6.25-5.25-6.25-9.75a6.25 6.25 0 1112.5 0c0 4.5-6.25 9.75-6.25 9.75z"/><circle cx="9.75" cy="7.75" r="1.75"/></svg>
        Jupiter, FL 33469
      </span>

      <!-- Language selector -->
      <div class="lang-wrap" id="langWrap">
        <button class="lang-btn" id="langBtn" aria-haspopup="listbox" aria-expanded="false">
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="10" cy="10" r="8"/><path d="M10 2a14.5 14.5 0 010 16M2 10h16" stroke-linecap="round"/><path d="M3.5 6.5C5.3 7.3 7.6 7.8 10 7.8s4.7-.5 6.5-1.3M3.5 13.5C5.3 12.7 7.6 12.2 10 12.2s4.7.5 6.5 1.3" stroke-linecap="round"/></svg>
          <span id="langLabel">Language</span>
          <svg class="lang-chevron" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 6l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <ul class="lang-dropdown" id="langDropdown" role="listbox">
          <li role="option" data-lang="en">🇺🇸 English</li>
          <li role="option" data-lang="es">🇪🇸 Español</li>
          <li role="option" data-lang="pt">🇧🇷 Português</li>
          <li role="option" data-lang="fr">🇫🇷 Français</li>
          <li role="option" data-lang="de">🇩🇪 Deutsch</li>
          <li role="option" data-lang="it">🇮🇹 Italiano</li>
          <li role="option" data-lang="nl">🇳🇱 Nederlands</li>
          <li role="option" data-lang="pl">🇵🇱 Polski</li>
          <li role="option" data-lang="ru">🇷🇺 Русский</li>
          <li role="option" data-lang="uk">🇺🇦 Українська</li>
          <li role="option" data-lang="ar">🇸🇦 العربية</li>
          <li role="option" data-lang="he">🇮🇱 עברית</li>
          <li role="option" data-lang="hi">🇮🇳 हिन्दी</li>
          <li role="option" data-lang="bn">🇧🇩 বাংলা</li>
          <li role="option" data-lang="zh-CN">🇨🇳 中文 (简体)</li>
          <li role="option" data-lang="zh-TW">🇹🇼 中文 (繁體)</li>
          <li role="option" data-lang="ja">🇯🇵 日本語</li>
          <li role="option" data-lang="ko">🇰🇷 한국어</li>
          <li role="option" data-lang="vi">🇻🇳 Tiếng Việt</li>
          <li role="option" data-lang="th">🇹🇭 ภาษาไทย</li>
          <li role="option" data-lang="id">🇮🇩 Bahasa Indonesia</li>
          <li role="option" data-lang="ms">🇲🇾 Bahasa Melayu</li>
          <li role="option" data-lang="tl">🇵🇭 Filipino</li>
          <li role="option" data-lang="tr">🇹🇷 Türkçe</li>
          <li role="option" data-lang="fa">🇮🇷 فارسی</li>
          <li role="option" data-lang="sw">🇰🇪 Kiswahili</li>
          <li role="option" data-lang="ht">🇭🇹 Kreyòl Ayisyen</li>
        </ul>
      </div>

    </div>
  </div>

  <div class="nav-bar">
    <div class="container nav-bar__inner">
      <a href="/" class="logo" aria-label="AMG Junk Removal LLC">
        <img src="/logo.png" alt="AMG Junk Removal LLC" class="logo__img" />
        <div class="logo__text">
          <span class="logo__brand">AMG JUNK REMOVAL</span>
          <span class="logo__sub">LLC</span>
        </div>
      </a>

      <nav class="nav" id="mainNav" aria-label="Main">
        <ul class="nav__list">
          <li><a href="#services"    class="nav__link">Services</a></li>
          <li><a href="#how-it-works" class="nav__link">How It Works</a></li>
          <li><a href="#why-us"      class="nav__link">Why Us</a></li>
          <li><a href="#areas"       class="nav__link">Areas</a></li>
          <li><a href="#reviews"     class="nav__link">Reviews</a></li>
          <li><a href="#faq"         class="nav__link">FAQ</a></li>
        </ul>
      </nav>

      <div class="nav-bar__actions">
        <a href="tel:+15614607921" class="btn btn-ghost-dark hidden-md">
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 3.5A1.5 1.5 0 013.5 2h1.148a1 1 0 01.95.684l.93 2.8a1 1 0 01-.23 1.02L5.1 7.7a11.04 11.04 0 005.2 5.2l1.196-1.198a1 1 0 011.02-.23l2.8.93A1 1 0 0116 13.35v1.15A1.5 1.5 0 0114.5 16C7.596 16 2 10.404 2 3.5z"/></svg>
          Call Us
        </a>
        <button class="burger" id="burger" aria-label="Menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  /* ── Burger ── */
  const burger = document.getElementById("burger")!;
  const nav    = document.getElementById("mainNav")!;
  burger.addEventListener("click", () => {
    const open = burger.getAttribute("aria-expanded") === "true";
    burger.setAttribute("aria-expanded", String(!open));
    burger.classList.toggle("is-open");
    nav.classList.toggle("is-open");
  });

  /* ── Language switcher ── */
  const langBtn      = document.getElementById("langBtn")!;
  const langDropdown = document.getElementById("langDropdown")!;
  const langLabel    = document.getElementById("langLabel")!;
  const langWrap     = document.getElementById("langWrap")!;

  const LANG_NAMES: Record<string, string> = {
    en: "English", es: "Español", pt: "Português", fr: "Français",
    de: "Deutsch", it: "Italiano", nl: "Nederlands", pl: "Polski",
    ru: "Русский", uk: "Українська", ar: "العربية", he: "עברית",
    hi: "हिन्दी", bn: "বাংলা", "zh-CN": "中文(简)", "zh-TW": "中文(繁)",
    ja: "日本語", ko: "한국어", vi: "Tiếng Việt", th: "ภาษาไทย",
    id: "Bahasa ID", ms: "Bahasa MY", tl: "Filipino", tr: "Türkçe",
    fa: "فارسی", sw: "Kiswahili", ht: "Kreyòl"
  };

  /* Toggle dropdown */
  langBtn.addEventListener("click", (e) => {
    e.stopPropagation();
    const isOpen = langBtn.getAttribute("aria-expanded") === "true";
    langBtn.setAttribute("aria-expanded", String(!isOpen));
    langDropdown.classList.toggle("is-open");
  });

  /* Close on outside click */
  document.addEventListener("click", () => {
    langBtn.setAttribute("aria-expanded", "false");
    langDropdown.classList.remove("is-open");
  });
  langDropdown.addEventListener("click", (e) => e.stopPropagation());

  /* Select language */
  langDropdown.querySelectorAll("li[data-lang]").forEach((li) => {
    li.addEventListener("click", () => {
      const code = (li as HTMLElement).dataset.lang!;
      langLabel.textContent = LANG_NAMES[code] ?? code;
      langBtn.setAttribute("aria-expanded", "false");
      langDropdown.classList.remove("is-open");
      translatePage(code);
    });
  });

  /* Google Translate helper */
  function translatePage(lang: string) {
    // Wait for the widget to be ready, then use its select element
    function doTranslate() {
      // @ts-ignore
      const gtCombo: HTMLSelectElement | null = document.querySelector(".goog-te-combo");
      if (gtCombo) {
        gtCombo.value = lang;
        gtCombo.dispatchEvent(new Event("change"));
        return true;
      }
      return false;
    }

    if (lang === "en") {
      // Reset: remove cookies and reload
      const exp = "expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/";
      document.cookie = `googtrans=; ${exp}`;
      document.cookie = `googtrans=; ${exp}; domain=.${location.hostname}`;
      location.reload();
      return;
    }

    // Try immediately, then poll until widget is ready
    if (!doTranslate()) {
      let attempts = 0;
      const poll = setInterval(() => {
        attempts++;
        if (doTranslate() || attempts > 40) clearInterval(poll);
      }, 150);
    }
  }
</script>

<!-- Google Translate widget (hidden, drives translations via .goog-te-combo select) -->
<div id="google_translate_element" style="position:absolute;width:1px;height:1px;overflow:hidden;opacity:0;pointer-events:none" aria-hidden="true"></div>
<script type="text/javascript">
  function googleTranslateElementInit() {
    // @ts-ignore
    new google.translate.TranslateElement(
      {
        pageLanguage: "en",
        includedLanguages: "en,es,pt,fr,de,it,nl,pl,ru,uk,ar,he,hi,bn,zh-CN,zh-TW,ja,ko,vi,th,id,ms,tl,tr,fa,sw,ht",
        autoDisplay: false,
        layout: 0
      },
      "google_translate_element"
    );
  }
</script>
<script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit" defer></script>

<style>
  /* ── Top bar ── */
  .top-bar { background: var(--ink-900); color: #fff; padding: 0.45rem 0; font-size: 0.78rem; border-bottom: 2px solid var(--red); }
  .top-bar__inner { display: flex; justify-content: flex-start; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .top-bar__item  { display: flex; align-items: center; gap: 0.4rem; font-weight: 500; opacity: 0.92; white-space: nowrap; flex-shrink: 0; }
  .top-bar__item svg { width: 14px; height: 14px; stroke: var(--red); flex-shrink: 0; }

  /* ── Language switcher ── */
  .lang-wrap { position: relative; margin-left: auto; flex-shrink: 0; }

  .lang-btn {
    display: flex; align-items: center; gap: 0.35rem;
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.18);
    color: #fff; border-radius: 6px; padding: 0.28rem 0.6rem;
    font-size: 0.75rem; font-weight: 500; cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    white-space: nowrap; flex-shrink: 0; max-width: 140px; overflow: hidden;
  }
  .lang-btn:hover { background: rgba(255,255,255,0.15); border-color: var(--red); }
  .lang-btn svg:first-child { width: 14px; height: 14px; flex-shrink: 0; }
  .lang-chevron { width: 12px; height: 12px; transition: transform 0.2s; flex-shrink: 0; }
  .lang-btn[aria-expanded="true"] .lang-chevron { transform: rotate(180deg); }
  #langLabel { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .lang-dropdown {
    display: none; position: absolute; top: calc(100% + 6px); right: 0;
    background: #fff; border: 1px solid var(--ink-200); border-radius: 8px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.14); min-width: 170px;
    max-height: 320px; overflow-y: auto; z-index: 9999;
    padding: 0.35rem 0; list-style: none;
    scrollbar-width: thin; scrollbar-color: var(--ink-200) transparent;
  }
  .lang-dropdown.is-open { display: block; }
  .lang-dropdown li {
    padding: 0.48rem 1rem; font-size: 0.8rem; font-weight: 500;
    color: var(--ink-700); cursor: pointer; white-space: nowrap;
    transition: background 0.15s, color 0.15s;
  }
  .lang-dropdown li:hover { background: var(--red-sub); color: var(--ink-900); }

  /* ── Nav bar ── */
  .nav-bar { background: #fff; border-bottom: 1px solid var(--ink-200); overflow: hidden; }
  .nav-bar__inner { display: flex; align-items: center; gap: 1rem; padding-top: 0.9rem; padding-bottom: 0.9rem; flex-wrap: nowrap; min-width: 0; }

  /* Logo */
  .logo { display: flex; align-items: center; gap: 0.65rem; flex-shrink: 0; }
  .logo__img   { width: 44px; height: 44px; object-fit: contain; flex-shrink: 0; }
  .logo__text  { display: flex; flex-direction: column; }
  .logo__brand { font-size: 1.05rem; font-weight: 900; color: var(--ink-900); line-height: 1; letter-spacing: -0.01em; white-space: nowrap; }
  .logo__sub   { font-size: 0.6rem; font-weight: 600; color: var(--ink-500); letter-spacing: 0.1em; text-transform: uppercase; white-space: nowrap; }

  /* Nav */
  .nav { margin-left: auto; min-width: 0; overflow: hidden; }
  .nav__list { display: flex; gap: 0; flex-wrap: nowrap; }
  .nav__link {
    display: block; padding: 0.45rem 0.55rem; font-size: 0.8rem; font-weight: 500;
    color: var(--ink-600); border-radius: 6px; transition: all var(--ease);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .nav__link:hover { color: #000A1A; background: rgba(0,10,26,0.06); }

  /* Actions */
  .nav-bar__actions { display: flex; align-items: center; gap: 0.6rem; flex-shrink: 0; margin-left: auto; }
  .btn-ghost-dark {
    background: transparent; color: var(--ink-700); border-color: var(--ink-300);
    font-size: 0.83rem; padding: 0.55rem 1.1rem; white-space: nowrap; flex-shrink: 0;
  }
  .btn-ghost-dark:hover { background: var(--ink-100); }
  .btn-ghost-dark svg { stroke: var(--ink-600); }

  /* Burger */
  .burger { display: none; flex-direction: column; gap: 5px; background: none; border: none; padding: 6px; }
  .burger span { display: block; width: 22px; height: 1.5px; background: var(--ink-700); border-radius: 2px; transition: all 0.25s; }
  .burger.is-open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .burger.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .burger.is-open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* Suppress Google Translate banner (backup, Layout.astro has the canonical rules) */
  :global(.goog-te-banner-frame)   { display: none !important; }
  :global(body.translated-ltr),
  :global(body.translated-rtl)     { top: 0 !important; margin-top: 0 !important; }
  :global(.skiptranslate > iframe) { display: none !important; height: 0 !important; }

  @media (max-width: 1024px) {
    .nav {
      display: none; position: absolute; top: 100%; left: 0; right: 0;
      background: #fff; border-bottom: 1px solid var(--ink-200);
      padding: 1rem 1.5rem; box-shadow: var(--sh-lg); z-index: 999;
      overflow: visible;
    }
    .nav.is-open { display: block; }
    .nav__list { flex-direction: column; gap: 0.1rem; }
    .nav__link {
      display: block; padding: 0.6rem 0.75rem; font-size: 0.9rem;
      white-space: normal; overflow: visible; text-overflow: unset;
    }
    .nav-bar__inner { position: relative; flex-wrap: wrap; gap: 0.5rem; }
    .nav { margin-left: 0; }
    .hidden-md { display: none; }
    .burger { display: flex; }
    /* On mobile the nav actions don't need margin-left:auto since nav is hidden */
    .nav-bar__actions { margin-left: auto; }
  }

  @media (max-width: 480px) {
    .top-bar__inner { justify-content: center; flex-wrap: wrap; gap: 0.5rem; }
    #langLabel { display: none; }
    .top-bar__item:nth-child(2) { display: none; }
  }
</style>
