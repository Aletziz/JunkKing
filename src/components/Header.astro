<script>
  /* ── Drawer / Burger ── */
  const burger       = document.getElementById("burger")!;
  const drawer       = document.getElementById("drawer")!;
  const overlay      = document.getElementById("drawerOverlay")!;
  const drawerClose  = document.getElementById("drawerClose")!;

  function openDrawer() {
    drawer.classList.add("is-open");
    overlay.classList.add("is-open");
    burger.setAttribute("aria-expanded", "true");
    burger.classList.add("is-open");
    drawer.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  }

  function closeDrawer() {
    drawer.classList.remove("is-open");
    overlay.classList.remove("is-open");
    burger.setAttribute("aria-expanded", "false");
    burger.classList.remove("is-open");
    drawer.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  burger.addEventListener("click", () => {
    drawer.classList.contains("is-open") ? closeDrawer() : openDrawer();
  });
  drawerClose.addEventListener("click", closeDrawer);
  overlay.addEventListener("click", closeDrawer);

  // Close on nav link click
  drawer.querySelectorAll(".drawer__link, .drawer__cta").forEach((link) => {
    link.addEventListener("click", closeDrawer);
  });

  // Close on Escape key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeDrawer();
  });
  const nav    = document.getElementById("mainNav")!;
  burger.addEventListener("click", () => {
    const open = burger.getAttribute("aria-expanded") === "true";
    burger.setAttribute("aria-expanded", String(!open));
    burger.classList.toggle("is-open");
    nav.classList.toggle("is-open");
  });

  /* ── Language switcher ── */
  const langBtn      = document.getElementById("langBtn")!;
  const langDropdown = document.getElementById("langDropdown")!;
  const langLabel    = document.getElementById("langLabel")!;
  const langWrap     = document.getElementById("langWrap")!;

  const LANG_NAMES: Record<string, string> = {
    en: "English", es: "Español", pt: "Português", fr: "Français",
    de: "Deutsch", it: "Italiano", nl: "Nederlands", pl: "Polski",
    ru: "Русский", uk: "Українська", ar: "العربية", he: "עברית",
    hi: "हिन्दी", bn: "বাংলা", "zh-CN": "中文(简)", "zh-TW": "中文(繁)",
    ja: "日本語", ko: "한국어", vi: "Tiếng Việt", th: "ภาษาไทย",
    id: "Bahasa ID", ms: "Bahasa MY", tl: "Filipino", tr: "Türkçe",
    fa: "فارسی", sw: "Kiswahili", ht: "Kreyòl"
  };

  /* Toggle dropdown */
  langBtn.addEventListener("click", (e) => {
    e.stopPropagation();
    const isOpen = langBtn.getAttribute("aria-expanded") === "true";
    langBtn.setAttribute("aria-expanded", String(!isOpen));
    langDropdown.classList.toggle("is-open");
  });

  /* Close on outside click */
  document.addEventListener("click", () => {
    langBtn.setAttribute("aria-expanded", "false");
    langDropdown.classList.remove("is-open");
  });
  langDropdown.addEventListener("click", (e) => e.stopPropagation());

  /* Select language */
  langDropdown.querySelectorAll("li[data-lang]").forEach((li) => {
    li.addEventListener("click", () => {
      const code = (li as HTMLElement).dataset.lang!;
      langLabel.textContent = LANG_NAMES[code] ?? code;
      langBtn.setAttribute("aria-expanded", "false");
      langDropdown.classList.remove("is-open");
      translatePage(code);
    });
  });

  /* ── Google Translate: in-page, no redirect, no reload ── */

  // Language pending while widget initialises
  let _pendingLang: string | null = null;
  let _gtReady = false;

  // Apply language via the hidden GT combo select
  function applyGTLang(lang: string) {
    // @ts-ignore
    const combo = document.querySelector<HTMLSelectElement>(".goog-te-combo");
    if (!combo) return false;
    combo.value = lang;
    combo.dispatchEvent(new Event("change"));
    return true;
  }

  // Called once the widget is confirmed ready
  function onGTReady() {
    _gtReady = true;
    if (_pendingLang) {
      applyGTLang(_pendingLang);
      _pendingLang = null;
    }
  }

  // MutationObserver waits for .goog-te-combo to appear in the DOM
  const _gtObserver = new MutationObserver(() => {
    // @ts-ignore
    if (document.querySelector(".goog-te-combo")) {
      _gtObserver.disconnect();
      onGTReady();
    }
  });
  _gtObserver.observe(document.body, { childList: true, subtree: true });

  // Restore label from localStorage on page load
  const _savedLang = localStorage.getItem("gtLang");
  if (_savedLang && _savedLang !== "en") {
    langLabel.textContent = LANG_NAMES[_savedLang] ?? _savedLang;
    _pendingLang = _savedLang;          // will be applied once observer fires
  }

  function translatePage(lang: string) {
    // Persist selection
    localStorage.setItem("gtLang", lang);

    if (lang === "en") {
      // Revert to original language — set combo to "en" + fire change
      langLabel.textContent = "Language";
      localStorage.removeItem("gtLang");
      if (_gtReady) {
        applyGTLang("en");
      } else {
        _pendingLang = "en";
      }
      return;
    }

    if (_gtReady) {
      applyGTLang(lang);
    } else {
      // Widget not ready yet — observer will fire applyGTLang when ready
      _pendingLang = lang;
      // Re-arm observer in case it was already disconnected
      // @ts-ignore
      if (!document.querySelector(".goog-te-combo")) {
        _gtObserver.observe(document.body, { childList: true, subtree: true });
      } else {
        _gtReady = true;
        applyGTLang(lang);
        _pendingLang = null;
      }
    }
  }
</script>

<!-- Google Translate widget: hidden in DOM, drives translation via .goog-te-combo -->
<div id="google_translate_element" style="position:absolute;width:1px;height:1px;overflow:hidden;opacity:0;pointer-events:none" aria-hidden="true"></div>
<script type="text/javascript">
  function googleTranslateElementInit() {
    // @ts-ignore
    new google.translate.TranslateElement(
      {
        pageLanguage: "en",
        includedLanguages: "en,es,pt,fr,de,it,nl,pl,ru,uk,ar,he,hi,bn,zh-CN,zh-TW,ja,ko,vi,th,id,ms,tl,tr,fa,sw,ht",
        autoDisplay: false,
        layout: 0
      },
      "google_translate_element"
    );
  }
</script>
<!-- async (not defer) so the callback is available as a global before DOMContentLoaded -->
<script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit" async></script>

<style>
  /* ── Sticky header ── */
  header {
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  /* ── Top bar ── */
  .top-bar { background: var(--ink-900); color: #fff; padding: 0.45rem 0; font-size: 0.78rem; border-bottom: 2px solid var(--red); }
  .top-bar__inner { display: flex; justify-content: flex-start; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .top-bar__item  { display: flex; align-items: center; gap: 0.4rem; font-weight: 500; opacity: 0.92; white-space: nowrap; flex-shrink: 0; }
  .top-bar__item svg { width: 14px; height: 14px; stroke: var(--red); flex-shrink: 0; }

  /* ── Language switcher ── */
  .lang-wrap { position: relative; margin-left: auto; flex-shrink: 0; }
  .lang-btn {
    display: flex; align-items: center; gap: 0.35rem;
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.18);
    color: #fff; border-radius: 6px; padding: 0.28rem 0.6rem;
    font-size: 0.75rem; font-weight: 500; cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    white-space: nowrap; flex-shrink: 0; max-width: 140px; overflow: hidden;
  }
  .lang-btn:hover { background: rgba(255,255,255,0.15); border-color: var(--red); }
  .lang-btn svg:first-child { width: 14px; height: 14px; flex-shrink: 0; }
  .lang-chevron { width: 12px; height: 12px; transition: transform 0.2s; flex-shrink: 0; }
  .lang-btn[aria-expanded="true"] .lang-chevron { transform: rotate(180deg); }
  #langLabel { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .lang-dropdown {
    display: none; position: absolute; top: calc(100% + 6px); right: 0;
    background: #fff; border: 1px solid var(--ink-200); border-radius: 8px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.14); min-width: 170px;
    max-height: 320px; overflow-y: auto; z-index: 9999;
    padding: 0.35rem 0; list-style: none;
    scrollbar-width: thin; scrollbar-color: var(--ink-200) transparent;
  }
  .lang-dropdown.is-open { display: block; }
  .lang-dropdown li {
    padding: 0.48rem 1rem; font-size: 0.8rem; font-weight: 500;
    color: var(--ink-700); cursor: pointer; white-space: nowrap;
    transition: background 0.15s, color 0.15s;
  }
  .lang-dropdown li:hover { background: var(--red-sub); color: var(--ink-900); }

  /* ── Nav bar ── */
  .nav-bar { background: #fff; border-bottom: 1px solid var(--ink-200); }
  .nav-bar__inner { display: flex; align-items: center; gap: 1rem; padding-top: 0.9rem; padding-bottom: 0.9rem; flex-wrap: nowrap; min-width: 0; }

  /* Logo */
  .logo { display: flex; align-items: center; gap: 0.65rem; flex-shrink: 0; text-decoration: none; }
  .logo__img   { width: 44px; height: 44px; object-fit: contain; flex-shrink: 0; }
  .logo__text  { display: flex; flex-direction: column; }
  .logo__brand { font-size: 1.05rem; font-weight: 900; color: var(--ink-900); line-height: 1; letter-spacing: -0.01em; white-space: nowrap; }
  .logo__sub   { font-size: 0.6rem; font-weight: 600; color: var(--ink-500); letter-spacing: 0.1em; text-transform: uppercase; white-space: nowrap; }

  /* Desktop nav */
  .nav { margin-left: auto; min-width: 0; overflow: hidden; }
  .nav__list { display: flex; gap: 0; flex-wrap: nowrap; list-style: none; }
  .nav__link {
    display: block; padding: 0.45rem 0.55rem; font-size: 0.8rem; font-weight: 500;
    color: var(--ink-600); border-radius: 6px; transition: all var(--ease);
    white-space: nowrap;
  }
  .nav__link:hover { color: var(--ink-900); background: rgba(0,10,26,0.06); }

  /* Actions */
  .nav-bar__actions { display: flex; align-items: center; gap: 0.6rem; flex-shrink: 0; margin-left: auto; }
  .btn-ghost-dark {
    background: transparent; color: var(--ink-700); border-color: var(--ink-300);
    font-size: 0.83rem; padding: 0.55rem 1.1rem; white-space: nowrap; flex-shrink: 0;
  }
  .btn-ghost-dark:hover { background: var(--ink-100); }
  .btn-ghost-dark svg { stroke: var(--ink-600); }

  /* Call Us — botón destacado azul marino */
  .btn-nav-call {
    background: var(--ink-900);
    color: #fff;
    border-color: var(--ink-900);
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.6rem 1.25rem;
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: 0.01em;
    box-shadow: 0 2px 8px rgba(0,10,26,0.25);
    transition: background 0.2s, box-shadow 0.2s, transform 0.15s;
  }
  .btn-nav-call:hover {
    background: #001433;
    border-color: #001433;
    box-shadow: 0 4px 14px rgba(0,10,26,0.35);
    transform: translateY(-1px);
  }
  .btn-nav-call svg { stroke: #fff; }

  /* Burger button */
  .burger {
    display: none; flex-direction: column; justify-content: center; gap: 5px;
    background: none; border: 1px solid var(--ink-200); border-radius: 8px;
    padding: 8px 9px; cursor: pointer; flex-shrink: 0;
    transition: background 0.2s, border-color 0.2s;
  }
  .burger:hover { background: var(--ink-100); border-color: var(--ink-300); }
  .burger span { display: block; width: 20px; height: 1.5px; background: var(--ink-700); border-radius: 2px; transition: all 0.28s cubic-bezier(.4,0,.2,1); }
  .burger.is-open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .burger.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .burger.is-open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* ── Drawer overlay ── */
  .drawer-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(0,10,26,0.55); backdrop-filter: blur(3px);
    z-index: 1100; opacity: 0; transition: opacity 0.3s ease;
  }
  .drawer-overlay.is-open { display: block; opacity: 1; }

  /* ── Drawer panel ── */
  .drawer {
