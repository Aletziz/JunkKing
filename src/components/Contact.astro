---
const services = [
  "Furniture Removal", "Appliance Removal", "Electronics Recycling",
  "Mattress Removal", "Hot Tub Removal", "Yard Waste Removal",
  "Full Space Cleanout", "Dumpster Bag Pickup",
];
---

<section class="contact" id="contact">
  <div class="container">
    <div class="contact__layout">

      <!-- Info side -->
      <div class="contact__info">
        <span class="eyebrow" style="color:rgba(255,255,255,0.55);">Contact Us</span>
        <div class="accent-line" style="margin:0.6rem 0 1rem;"></div>
        <h2 class="h2" style="text-align:left;color:#fff;">Get a Free<br/>Quote Today</h2>
        <p style="font-size:0.9rem;color:rgba(255,255,255,0.6);line-height:1.7;margin-top:1rem;margin-bottom:2.5rem;">
          Ready to reclaim your space? Book online and save $20, or reach out directly.
          Our team responds fast — same-day service available.
        </p>

        <ul class="contact__details">
          <li>
            <div class="contact__detail-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.5 19.79 19.79 0 01.02 2.84 2 2 0 012 .67h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.49a16 16 0 006.29 6.29l1.1-1.1a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
              </svg>
            </div>
            <div>
              <span class="contact__detail-label">Phone</span>
              <a href="tel:+15612466352" class="contact__detail-value">(561) 246-6352</a>
            </div>
          </li>
          <li>
            <div class="contact__detail-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
              </svg>
            </div>
            <div>
              <span class="contact__detail-label">Text</span>
              <a href="sms:17378885865" class="contact__detail-value">1-737-888-5865</a>
            </div>
          </li>
          <li>
            <div class="contact__detail-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                <circle cx="12" cy="9" r="2.5"/>
              </svg>
            </div>
            <div>
              <span class="contact__detail-label">Address</span>
              <span class="contact__detail-value">1559 S Cypress Dr, Unit 3<br/>Jupiter, FL 33469</span>
            </div>
          </li>
          <li>
            <div class="contact__detail-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
              </svg>
            </div>
            <div>
              <span class="contact__detail-label">Hours</span>
              <span class="contact__detail-value">Mon–Sat 7 AM – 8 PM<br/>Sun 8 AM – 5 PM</span>
            </div>
          </li>
        </ul>

        <!-- Social -->
        <div class="contact__social">
          <a href="#" class="contact__social-link" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a href="#" class="contact__social-link" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.5" y2="6.5" stroke-width="2.5" stroke-linecap="round"/></svg>
          </a>
          <a href="#" class="contact__social-link" aria-label="YouTube">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 001.46 6.42 29 29 0 001 12a29 29 0 00.46 5.58 2.78 2.78 0 001.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.96A29 29 0 0023 12a29 29 0 00-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="#" class="contact__social-link" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        </div>
      </div>

      <!-- Form side -->
      <div class="contact__form-wrap">
        <div class="contact__form-header">
          <span class="contact__form-badge">Save $20</span>
          <span>Book Online &amp; Get $20 Off</span>
        </div>
        <form class="contact__form" action="#" method="POST" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="first-name">First Name</label>
              <input type="text" id="first-name" name="first_name" placeholder="John" required />
            </div>
            <div class="form-group">
              <label for="last-name">Last Name</label>
              <input type="text" id="last-name" name="last_name" placeholder="Smith" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" placeholder="john@example.com" required />
            </div>
            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone" placeholder="(561) 000-0000" />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="zip">ZIP Code</label>
              <input type="text" id="zip" name="zip" placeholder="33401" />
            </div>
            <div class="form-group">
              <label for="service">Service Needed</label>
              <select id="service" name="service">
                <option value="">Select a service…</option>
                {services.map((s) => <option value={s}>{s}</option>)}
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="message">Tell Us About Your Job <span>(optional)</span></label>
            <textarea id="message" name="message" placeholder="Describe what needs to be removed…" rows="3"></textarea>
          </div>
          <label class="form-check">
            <input type="checkbox" name="sms_opt_in" />
            <span>I agree to receive SMS/text appointment reminders and updates.</span>
          </label>
          <button type="submit" class="btn btn-primary btn-lg form-submit">
            Get My Free Quote — Save $20
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M4 10h12M11 5l6 5-6 5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </form>
      </div>

    </div>
  </div>
</section>

<style>
  .contact { padding: 6rem 0; background: var(--ink-900); }
  .contact__layout { display: grid; grid-template-columns: 1fr 1.2fr; gap: 5rem; align-items: start; }

  /* Info */
  .contact__details { display: flex; flex-direction: column; gap: 1.25rem; margin-bottom: 2.5rem; }
  .contact__details li { display: flex; align-items: flex-start; gap: 1rem; }
  .contact__detail-icon {
    width: 38px; height: 38px; background: rgba(0,247,247,0.08);
    border-radius: var(--r); display: flex; align-items: center;
    justify-content: center; flex-shrink: 0;
    border: 1px solid rgba(0,247,247,0.15);
  }
  .contact__detail-icon svg { width: 18px; height: 18px; stroke: var(--red); }
  .contact__detail-label { display: block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--red); opacity: 0.7; margin-bottom: 0.2rem; }
  .contact__detail-value { font-size: 0.88rem; color: rgba(255,255,255,0.8); line-height: 1.55; text-decoration: none; }
  a.contact__detail-value:hover { color: #fff; text-decoration: underline; }

  .contact__social { display: flex; gap: 0.75rem; }
  .contact__social-link {
    width: 36px; height: 36px; background: rgba(255,255,255,0.07);
    border-radius: var(--r); display: flex; align-items: center;
    justify-content: center; color: rgba(255,255,255,0.4);
    transition: all var(--ease);
  }
  .contact__social-link:hover { background: rgba(255,255,255,0.12); color: #fff; }
  .contact__social-link svg { width: 16px; height: 16px; }

  /* Form */
  .contact__form-wrap {
    background: var(--white); border-radius: var(--r-xl); overflow: hidden;
  }
  .contact__form-header {
    background: var(--red); padding: 1rem 2rem;
    display: flex; align-items: center; gap: 0.75rem;
    font-size: 0.9rem; font-weight: 700; color: var(--ink-900);
  }
  .contact__form-badge {
    background: rgba(0,0,0,0.12); border-radius: 20px;
    padding: 0.2rem 0.65rem; font-size: 0.75rem; color: var(--ink-900);
  }
  .contact__form { padding: 2rem; display: flex; flex-direction: column; gap: 1rem; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .form-group label { font-size: 0.78rem; font-weight: 600; color: var(--ink-700); }
  .form-group label span { font-weight: 400; color: var(--ink-400); }
  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.7rem 0.875rem; border: 1px solid var(--ink-200);
    border-radius: var(--r); font-size: 0.875rem; color: var(--ink-900);
    font-family: var(--font); background: var(--white);
    transition: border-color var(--ease);
    outline: none;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus { border-color: var(--red); box-shadow: 0 0 0 3px var(--red-sub); }
  .form-group textarea { resize: vertical; min-height: 80px; }
  .form-group select { cursor: pointer; }

  .form-check { display: flex; align-items: flex-start; gap: 0.6rem; cursor: pointer; }
  .form-check input { margin-top: 2px; accent-color: var(--red); }
  .form-check span { font-size: 0.78rem; color: var(--ink-500); line-height: 1.5; }

  .form-submit {
    display: flex; align-items: center; justify-content: center;
    gap: 0.6rem; width: 100%;
  }
  .form-submit svg { width: 18px; height: 18px; stroke: var(--ink-900); }

  @media (max-width: 1024px) {
    .contact__layout { grid-template-columns: 1fr; gap: 3rem; }
  }
  @media (max-width: 768px) {
    .contact { padding: 4rem 0; }
    .form-row { grid-template-columns: 1fr; }
    .contact__form { padding: 1.5rem; }
    .contact__form-header { padding: 1rem 1.5rem; }
  }
</style>
