---
const services = [
  {
    title: "Rent",
    desc: "Need a truck or dumpster for your project? Rent our equipment at competitive rates — flexible durations, no hidden fees.",
    bullets: ["Flexible rental periods", "Trucks & dumpsters available", "No hidden charges"],
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="1" y="10" width="15" height="10" rx="1"/><path d="M16 13h4l3 3v4h-7V13z"/><circle cx="5.5" cy="20.5" r="1.5"/><circle cx="18.5" cy="20.5" r="1.5"/></svg>`,
  },
  {
    title: "Junk Removal",
    desc: "We haul away anything — furniture, appliances, yard waste, full property cleanouts. You point, we lift and load.",
    bullets: ["Same-day appointments", "Free on-site estimates", "Up to 60% recycled or donated"],
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M1 3h4l2.68 13.39a2 2 0 001.98 1.61h9.72a2 2 0 001.98-1.61L23 6H6"/><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/></svg>`,
  },
  {
    title: "Sod Installer",
    desc: "Transform your lawn in a single day. We source, deliver and install fresh sod for residential and commercial properties.",
    bullets: ["Residential & commercial", "Same-day installation", "Clean, professional finish"],
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="14" width="20" height="6" rx="1"/><path d="M5 14V9M9 14V7M13 14V10M17 14V8"/><path d="M3 9c1-2 3-3 6-3s5 1 6 3"/></svg>`,
  },
  {
    title: "Fast Delivery & Pickup",
    desc: "Same-day delivery and pickup of materials, bags, or items anywhere in Palm Beach County. Fast, reliable, on-time.",
    bullets: ["Same-day availability", "Materials, bags & items", "All Palm Beach County"],
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h11a2 2 0 012 2v3"/><rect x="9" y="11" width="14" height="10" rx="1"/><circle cx="12" cy="21" r="1"/><circle cx="20" cy="21" r="1"/></svg>`,
  },
];
---

<section class="services" id="services">
  <div class="container">

    <!-- Header -->
    <div class="tc services__header reveal">
      <span class="eyebrow">What We Do</span>
      <div class="accent-line"></div>
      <h2 class="h2">Four Services.<br/>One Reliable Crew.</h2>
      <p class="lead">
        From hauling junk to laying fresh sod and same-day deliveries —
        we've got Palm Beach County covered.
      </p>
    </div>

    <!-- 4 main services grid -->
    <div class="service-cards reveal-group">
      {services.map((s) => (
        <div class="service-card">
          <div class="service-card__icon" set:html={s.icon}></div>
          <h3 class="service-card__title">{s.title}</h3>
          <p class="service-card__desc">{s.desc}</p>
          <ul class="service-card__bullets">
            {s.bullets.map((b) => (
              <li>
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 8l3 3 7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {b}
              </li>
            ))}
          </ul>
          <a href="#contact" class="service-card__cta">Request Service</a>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .services { padding: 6rem 0; background: var(--ink-50); }
  .services__header { margin-bottom: 4rem; }
  .services__header .lead { margin: 0 auto; }
  .services__header .eyebrow { color: #000A1A; }

  /* 4 service cards grid */
  .service-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .service-card {
    background: var(--white);
    border: 1px solid var(--ink-200);
    border-radius: var(--r-lg);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: all var(--ease);
  }
  .service-card:hover {
    border-color: #000A1A;
    transform: translateY(-4px);
    box-shadow: var(--sh-md);
  }

  .service-card__icon {
    width: 48px; height: 48px;
    background: var(--red-sub);
    border-radius: var(--r);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.25rem;
    flex-shrink: 0;
  }
  .service-card__icon svg { width: 22px; height: 22px; stroke: #000A1A; }

  .service-card__title {
    font-size: 1rem; font-weight: 800;
    color: var(--ink-900); letter-spacing: -0.01em;
    margin-bottom: 0.6rem;
  }

  .service-card__desc {
    font-size: 0.85rem; color: var(--ink-500);
    line-height: 1.65; margin-bottom: 1.25rem;
  }

  .service-card__bullets {
    list-style: none; padding: 0; margin: 0 0 1.5rem;
    display: flex; flex-direction: column; gap: 0.55rem;
    flex: 1;
  }
  .service-card__bullets li {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.8rem; color: var(--ink-600); font-weight: 500;
  }
  .service-card__bullets svg {
    width: 14px; height: 14px;
    stroke: var(--red); flex-shrink: 0;
  }

  .service-card__cta {
    display: inline-block; padding: 0.6rem 1.25rem;
    background: transparent; border: 1.5px solid #000A1A;
    border-radius: var(--r); color: var(--ink-900);
    font-size: 0.82rem; font-weight: 700;
    text-decoration: none; text-align: center;
    transition: all var(--ease);
    margin-top: auto;
  }
  .service-card__cta:hover {
    background: #000A1A; color: var(--white);
  }

  @media (max-width: 1024px) {
    .service-cards { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .services { padding: 4rem 0; }
    .service-cards { grid-template-columns: 1fr; }
  }
</style>
