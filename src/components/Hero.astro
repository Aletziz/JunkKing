---
---
<section class="hero" id="home">
  <div class="hero-bg">
    <div class="hero-overlay"></div>
    <div class="hero-pattern"></div>
  </div>

  <div class="container hero-content">
    <div class="hero-badge">
      <span>⭐ 983 Customer Reviews · 5/5 Rating</span>
    </div>
    <h1 class="hero-title">
      Junk King <span class="highlight">Palm Beach</span>
    </h1>
    <p class="hero-tagline">Fast, Eco-Friendly Junk Removal Service</p>
    <p class="hero-desc">
      Palm Beach's #1 rated junk removal company. Same-day appointments, free estimates,
      and we do all the heavy lifting — so you don't have to lift a finger.
    </p>

    <div class="hero-cta">
      <a href="#contact" class="btn btn-primary btn-lg">
        📅 Book Online — Save $20
      </a>
      <a href="tel:5612466352" class="btn btn-white btn-lg">
        📞 (561) 246-6352
      </a>
    </div>

    <div class="hero-stats">
      <div class="stat">
        <span class="stat-number">983+</span>
        <span class="stat-label">5-Star Reviews</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number">60%</span>
        <span class="stat-label">Recycled or Donated</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number">Same</span>
        <span class="stat-label">Day Appointments</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number">Free</span>
        <span class="stat-label">Estimates</span>
      </div>
    </div>
  </div>

  <div class="hero-offer">
    <div class="container">
      <div class="offer-banner">
        <span class="offer-badge">🏷️ SPECIAL OFFER</span>
        <strong>$20 OFF</strong> when you book online · Expires Sep 30, 2026
        <a href="#contact" class="btn btn-white">Claim Offer</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 0 0;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      #0d0d0d 0%,
      #1a0408 40%,
      #2c0610 70%,
      #1a0408 100%
    );
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 50%, rgba(200, 16, 46, 0.25) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(200, 16, 46, 0.15) 0%, transparent 40%),
      radial-gradient(circle at 60% 80%, rgba(45, 122, 45, 0.1) 0%, transparent 40%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 3rem;
    padding-bottom: 3rem;
    max-width: 800px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #ffd700;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.4rem 1rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(10px);
  }

  .hero-title {
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 900;
    color: var(--color-white);
    line-height: 1.05;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .highlight {
    color: var(--color-primary);
    display: block;
  }

  .hero-tagline {
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 1.25rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .hero-desc {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.8);
    max-width: 580px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 0;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--border-radius-lg);
    padding: 1.25rem 2rem;
    backdrop-filter: blur(10px);
    width: fit-content;
    flex-wrap: wrap;
    gap: 0;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 1.75rem;
  }

  .stat:first-child {
    padding-left: 0;
  }

  .stat-number {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--color-white);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.3rem;
    white-space: nowrap;
  }

  .stat-divider {
    width: 1px;
    height: 36px;
    background: rgba(255, 255, 255, 0.15);
    flex-shrink: 0;
  }

  .hero-offer {
    position: relative;
    z-index: 1;
    background: var(--color-accent);
    padding: 0.75rem 0;
    margin-top: auto;
  }

  .offer-banner {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-gray-900);
  }

  .offer-badge {
    background: var(--color-gray-900);
    color: var(--color-accent);
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    letter-spacing: 0.08em;
  }

  .offer-banner .btn {
    margin-left: auto;
    padding: 0.4rem 1.25rem;
    font-size: 0.85rem;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: 3rem 0 0;
    }

    .hero-cta {
      flex-direction: column;
    }

    .hero-stats {
      gap: 0.75rem;
      padding: 1rem 1.25rem;
    }

    .stat {
      padding: 0 0.75rem;
    }

    .offer-banner {
      justify-content: center;
    }

    .offer-banner .btn {
      margin-left: 0;
      width: 100%;
    }
  }
</style>
