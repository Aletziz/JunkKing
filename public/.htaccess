# ═══════════════════════════════════════════════════════════════
#  AMG Junk Removal LLC — Hostinger .htaccess
#  Apache 2.4 | Astro Static Site
#  Security A+ | Performance A+ | 5000+ concurrent users
# ═══════════════════════════════════════════════════════════════

Options -Indexes -MultiViews
ServerSignature Off

# ── 1. HTTPS FORCE ──────────────────────────────────────────────
RewriteEngine On

# HTTP → HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Remove www (canonical non-www)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# ── 2. BLOCK MALICIOUS REQUESTS ─────────────────────────────────
# Block common exploit patterns in query strings
RewriteCond %{QUERY_STRING} (union.*select|insert.*into|drop.*table|alert\(|<script|javascript:) [NC,OR]
RewriteCond %{QUERY_STRING} (base64_encode|GLOBALS|_REQUEST|localhost|loopback) [NC,OR]
RewriteCond %{QUERY_STRING} (\.\./|\.\.%2F|%00|%0d%0a) [NC]
RewriteRule .* - [F,L]

# Block bad bots / scanners
RewriteCond %{HTTP_USER_AGENT} (masscan|nikto|sqlmap|nmap|zgrab|nessus|openvas|w3af|dirbuster|hydra|havij) [NC]
RewriteRule .* - [F,L]

# Block empty User-Agent (most scrapers/bots)
RewriteCond %{HTTP_USER_AGENT} ^-?$
RewriteRule .* - [F,L]

# Block access to sensitive files
<FilesMatch "(^\.env|^\.git|composer\.(json|lock)|package(-lock)?\.json|yarn\.lock|tsconfig|astro\.config)">
  Order allow,deny
  Deny from all
</FilesMatch>

# Block hidden files/dirs (.htpasswd, .git, etc.)
<FilesMatch "^\.(?!well-known)">
  Order allow,deny
  Deny from all
</FilesMatch>

# ── 3. CONTENT SECURITY POLICY ──────────────────────────────────
<IfModule mod_headers.c>
  # CSP: solo permite recursos de nuestro dominio + Google Fonts + Google Translate
  Header always set Content-Security-Policy "\
default-src 'self'; \
script-src 'self' 'unsafe-inline' https://translate.googleapis.com https://translate.google.com https://www.google.com; \
style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://translate.googleapis.com; \
font-src 'self' https://fonts.gstatic.com; \
img-src 'self' data: https://www.google.com https://translate.googleapis.com https://www.gstatic.com; \
connect-src 'self' https://translate.googleapis.com; \
frame-src https://translate.google.com; \
object-src 'none'; \
base-uri 'self'; \
form-action 'self' https://api.whatsapp.com; \
upgrade-insecure-requests"

  # ── Security Headers ──
  Header always set X-Content-Type-Options      "nosniff"
  Header always set X-Frame-Options             "SAMEORIGIN"
  Header always set X-XSS-Protection            "1; mode=block"
  Header always set Referrer-Policy             "strict-origin-when-cross-origin"
  Header always set Permissions-Policy          "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=()"
  Header always set Cross-Origin-Opener-Policy  "same-origin-allow-popups"
  Header always set Cross-Origin-Resource-Policy "same-origin"

  # HSTS: 2 años + preload (registra el dominio en navegadores)
  Header always set Strict-Transport-Security   "max-age=63072000; includeSubDomains; preload"

  # Remove server info headers
  Header always unset X-Powered-By
  Header always unset Server

  # ── Cache-Control granular ──
  # HTML: sin caché (siempre fresco)
  <FilesMatch "\.(html|htm)$">
    Header always set Cache-Control "no-cache, no-store, must-revalidate"
    Header always set Pragma "no-cache"
  </FilesMatch>

  # JS/CSS con hash de Astro: inmutables 1 año
  <FilesMatch "\.(js|css|mjs)$">
    Header always set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Imágenes: 6 meses
  <FilesMatch "\.(jpg|jpeg|png|webp|gif|ico|svg)$">
    Header always set Cache-Control "public, max-age=15552000"
  </FilesMatch>

  # Fuentes: 1 año inmutables
  <FilesMatch "\.(woff2|woff|ttf|otf|eot)$">
    Header always set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Robots, sitemap: 1 día
  <FilesMatch "(robots\.txt|sitemap\.xml)$">
    Header always set Cache-Control "public, max-age=86400"
  </FilesMatch>
</IfModule>

# ── 4. COMPRESSION (Gzip + Brotli) ──────────────────────────────
# Brotli (Hostinger lo soporta)
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css text/javascript
  AddOutputFilterByType BROTLI_COMPRESS application/javascript application/json
  AddOutputFilterByType BROTLI_COMPRESS image/svg+xml font/woff2 font/woff
</IfModule>

# Gzip fallback
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css
  AddOutputFilterByType DEFLATE text/javascript application/javascript
  AddOutputFilterByType DEFLATE application/json image/svg+xml
  AddOutputFilterByType DEFLATE font/woff2 font/woff
  # No comprimir ya comprimidos
  SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|gz|zip|bz2|woff2)$ no-gzip dont-vary
</IfModule>

# ── 5. BROWSER CACHE (Expires) ───────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html              "access plus 0 seconds"
  ExpiresByType text/css               "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg             "access plus 6 months"
  ExpiresByType image/png              "access plus 6 months"
  ExpiresByType image/webp             "access plus 6 months"
  ExpiresByType image/svg+xml          "access plus 6 months"
  ExpiresByType image/x-icon           "access plus 1 year"
  ExpiresByType font/woff2             "access plus 1 year"
  ExpiresByType font/woff              "access plus 1 year"
  ExpiresByType application/json       "access plus 0 seconds"
  ExpiresByType text/xml               "access plus 1 day"
</IfModule>

# ── 6. ETAG (para validación eficiente) ──────────────────────────
FileETag MTime Size

# ── 7. KEEP-ALIVE (reutilizar conexiones TCP) ────────────────────
<IfModule mod_headers.c>
  Header always set Connection "keep-alive"
</IfModule>

# ── 8. MIME TYPES ────────────────────────────────────────────────
AddType image/webp             .webp
AddType font/woff2             .woff2
AddType application/javascript .mjs
AddType application/json       .json

# ── 9. PREVENT HOTLINKING (protege imágenes de otros sitios) ─────
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^https://(www\.)?amgjunkremovalpalmbeach\.com/ [NC]
RewriteCond %{HTTP_REFERER} !^https://www\.google\. [NC]
RewriteCond %{HTTP_REFERER} !^https://translate\.google\. [NC]
RewriteRule \.(jpg|jpeg|png|webp|gif|svg)$ - [F,L]

# ── 10. RATE LIMITING (bloquea flood de requests) ────────────────
<IfModule mod_ratelimit.c>
  <Location />
    SetOutputFilter RATE_LIMIT
    SetEnv rate-limit 600
  </Location>
</IfModule>

# ── 11. STATIC SITE ROUTING ──────────────────────────────────────
DirectoryIndex index.html

# Serve pre-compressed .br files if available (Brotli static)
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP:Accept-Encoding} br
  RewriteCond %{REQUEST_FILENAME}\.br -f
  RewriteRule (.*)$ $1.br [L]
  <FilesMatch "\.br$">
    Header set Content-Encoding br
    Header append Vary Accept-Encoding
  </FilesMatch>
</IfModule>

# Vary header para compresión correcta en CDN/proxies
<IfModule mod_headers.c>
  Header append Vary Accept-Encoding
  Header append Vary User-Agent
</IfModule>

# ── 12. ERROR PAGES ──────────────────────────────────────────────
ErrorDocument 400 /404.html
ErrorDocument 403 /404.html
ErrorDocument 404 /404.html
ErrorDocument 500 /404.html
ErrorDocument 503 /404.html

