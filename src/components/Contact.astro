---
const services = [
  "Rent (Truck / Dumpster)",
  "Junk Removal",
  "Sod Installation",
  "Fast Delivery & Pickup",
];
---

<section class="contact" id="contact">
  <div class="container">
    <div class="contact__layout">

      <!-- Info side -->
      <div class="contact__info reveal reveal--left">
        <span class="eyebrow" style="color:rgba(255,255,255,0.55);">Contact Us</span>
        <div class="accent-line" style="margin:0.6rem 0 1rem;"></div>
        <h2 class="h2" style="text-align:left;color:#fff;">Ready to Get<br/>Started Today?</h2>
        <p style="font-size:0.9rem;color:rgba(255,255,255,0.6);line-height:1.7;margin-top:1rem;margin-bottom:2.5rem;">
          Contact us now and we'll take care of the rest.
          Fast response, same-day service available across Palm Beach County.
        </p>

        <ul class="contact__details">
          <li>
            <div class="contact__detail-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.5 19.79 19.79 0 01.02 2.84 2 2 0 012 .67h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.49a16 16 0 006.29 6.29l1.1-1.1a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
              </svg>
            </div>
            <div>
              <span class="contact__detail-label">Phone</span>
              <a href="tel:+15617620065" class="contact__detail-value">(561) 762-0065</a>
            </div>
          </li>
          <li>
            <div class="contact__detail-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
              </svg>
            </div>
            <div>
              <span class="contact__detail-label">Text</span>
              <a href="sms:+15617620065" class="contact__detail-value">(561) 762-0065</a>
            </div>
          </li>
          <li>
            <div class="contact__detail-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
              </svg>
            </div>
            <div>
              <span class="contact__detail-label">Hours</span>
              <span class="contact__detail-value">Every day 7 AM – 7 PM</span>
            </div>
          </li>
        </ul>

        <!-- Payment methods -->
        <div class="contact__payment">
          <p class="contact__payment-label">We Accept</p>
          <div class="contact__payment-methods">
            <div class="pay-method">
              <div class="pay-method__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="5" width="20" height="14" rx="2"/>
                  <path d="M2 10h20M6 15h4" stroke-linecap="round"/>
                </svg>
              </div>
              <span>Credit Card</span>
            </div>
            <div class="pay-method">
              <div class="pay-method__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 2L2 7l10 5 10-5-10-5z" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M2 17l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <span>Zelle</span>
            </div>
            <div class="pay-method">
              <div class="pay-method__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="3" y="6" width="18" height="12" rx="1.5"/>
                  <circle cx="12" cy="12" r="3"/>
                  <path d="M3 10h2M19 10h2M3 14h2M19 14h2" stroke-linecap="round"/>
                </svg>
              </div>
              <span>Cash</span>
            </div>
          </div>
        </div>

      </div>

      <!-- Form side -->
      <div class="contact__form-wrap reveal reveal--right">
        <div class="contact__form-header">
          <svg viewBox="0 0 24 24" fill="currentColor" style="width:20px;height:20px;flex-shrink:0;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.845L.057 23.571a.75.75 0 00.92.92l5.726-1.471A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.969 0-3.81-.535-5.388-1.465l-.385-.23-3.993 1.026 1.055-3.872-.252-.4A9.953 9.953 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
          Contact via WhatsApp
        </div>
        <form class="contact__form" id="wa-form" novalidate>
          <!-- Honeypot anti-spam: campo oculto, los bots lo rellenan, humanos no -->
          <div class="hp-field" aria-hidden="true">
            <input type="text" name="website" tabindex="-1" autocomplete="off" />
          </div>
          <div class="form-group">
            <label for="wa-name">Your Name</label>
            <input type="text" id="wa-name" name="name" placeholder="John Smith" required maxlength="80" autocomplete="name" />
          </div>
          <div class="form-group">
            <label for="wa-service">Service Needed</label>
            <select id="wa-service" name="service" required>
              <option value="">Select a service…</option>
              {services.map((s) => <option value={s}>{s}</option>)}
            </select>
          </div>
          <div class="form-group">
            <label for="wa-zip">City / Area</label>
            <input type="text" id="wa-zip" name="zip" placeholder="e.g. West Palm Beach, Boca Raton…" required maxlength="60" autocomplete="address-level2" />
          </div>
          <div class="form-group">
            <label for="wa-msg">Brief Description <span>(optional)</span></label>
            <textarea id="wa-msg" name="message" placeholder="e.g. Old sofa, fridge and some boxes…" rows="3" maxlength="500"></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-lg form-submit">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.845L.057 23.571a.75.75 0 00.92.92l5.726-1.471A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.969 0-3.81-.535-5.388-1.465l-.385-.23-3.993 1.026 1.055-3.872-.252-.4A9.953 9.953 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
            Send via WhatsApp
          </button>
        </form>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById("wa-form") as HTMLFormElement;
  let lastSubmit = 0;

  form.addEventListener("submit", (e) => {
    e.preventDefault();

    // ── Anti-spam: honeypot check ──
    const honeypot = (form.querySelector('input[name="website"]') as HTMLInputElement).value;
    if (honeypot) return; // bot rellenó el campo oculto — ignorar silenciosamente

    // ── Rate limiting: 1 submit cada 30s ──
    const now = Date.now();
    if (now - lastSubmit < 30000) {
      alert("Please wait a moment before submitting again.");
      return;
    }

    const name    = (form.querySelector("#wa-name")    as HTMLInputElement).value.trim();
    const service = (form.querySelector("#wa-service") as HTMLSelectElement).value;
    const zip     = (form.querySelector("#wa-zip")     as HTMLInputElement).value.trim();
    const msg     = (form.querySelector("#wa-msg")     as HTMLTextAreaElement).value.trim();

    // ── Validación básica ──
    if (!name || !service || !zip) {
      alert("Please fill in your name, service and city.");
      return;
    }
    // Evitar XSS en los valores antes de enviar a WhatsApp
    const safe = (s: string) => s.replace(/[<>"'`]/g, "").substring(0, 200);

    lastSubmit = now;

    const text = [
      `Hi! I'd like to request a quote from AMG Junk Removal LLC.`,
      ``,
      `*Name:* ${safe(name)}`,
      `*Service:* ${safe(service)}`,
      `*City / Area:* ${safe(zip)}`,
      msg ? `*Details:* ${safe(msg)}` : "",
    ].filter(Boolean).join("\n");

    const url = `https://wa.me/15617620065?text=${encodeURIComponent(text)}`;
    window.open(url, "_blank", "noopener,noreferrer");
  });
</script>

<style>
  .contact { padding: 6rem 0; background: var(--ink-900); }
  /* Honeypot: visualmente invisible, accesible para bots */
  .hp-field {
    position: absolute;
    left: -9999px;
    top: -9999px;
    width: 1px; height: 1px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    tab-size: 0;
  }
  .contact__layout { display: grid; grid-template-columns: 1fr 1.2fr; gap: 5rem; align-items: start; }

  /* Info */
  .contact__details { display: flex; flex-direction: column; gap: 1.25rem; margin-bottom: 2.5rem; }
  .contact__details li { display: flex; align-items: flex-start; gap: 1rem; }
  .contact__detail-icon {
    width: 38px; height: 38px; background: rgba(0,247,247,0.08);
    border-radius: var(--r); display: flex; align-items: center;
    justify-content: center; flex-shrink: 0;
    border: 1px solid rgba(0,247,247,0.15);
  }
  .contact__detail-icon svg { width: 18px; height: 18px; stroke: var(--red); }
  .contact__detail-label { display: block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--red); opacity: 0.7; margin-bottom: 0.2rem; }
  .contact__detail-value { font-size: 0.88rem; color: rgba(255,255,255,0.8); line-height: 1.55; text-decoration: none; }
  a.contact__detail-value:hover { color: #fff; text-decoration: underline; }

  .contact__social { display: flex; gap: 0.75rem; }
  .contact__social-link {
    width: 36px; height: 36px; background: rgba(255,255,255,0.07);
    border-radius: var(--r); display: flex; align-items: center;
    justify-content: center; color: rgba(255,255,255,0.4);
    transition: all var(--ease);
  }
  .contact__social-link:hover { background: rgba(255,255,255,0.12); color: #fff; }
  .contact__social-link svg { width: 16px; height: 16px; }

  /* Payment methods */
  .contact__payment { margin-top: 2rem; }
  .contact__payment-label {
    font-size: 0.68rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.12em;
    color: rgba(255,255,255,0.35);
    margin-bottom: 0.85rem;
  }
  .contact__payment-methods {
    display: flex; gap: 0.75rem; flex-wrap: wrap;
  }
  .pay-method {
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 0.9rem 1.4rem;
    min-width: 82px;
    transition: background 0.18s, border-color 0.18s, transform 0.18s;
  }
  .pay-method:hover {
    background: rgba(0,200,200,0.08);
    border-color: rgba(0,200,200,0.35);
    transform: translateY(-2px);
  }
  .pay-method__icon {
    width: 40px; height: 40px;
    background: rgba(0,200,200,0.1);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid rgba(0,200,200,0.2);
  }
  .pay-method__icon svg { width: 20px; height: 20px; stroke: var(--red); }
  .pay-method span {
    font-size: 0.72rem; font-weight: 600;
    color: rgba(255,255,255,0.6);
    white-space: nowrap;
  }

  /* Form */
  .contact__form-wrap {
    background: var(--white); border-radius: var(--r-xl); overflow: hidden;
  }
  .contact__form-header {
    background: #25D366; padding: 1rem 2rem;
    display: flex; align-items: center; gap: 0.65rem;
    font-size: 0.95rem; font-weight: 700; color: #fff;
  }
  .contact__form { padding: 2rem; display: flex; flex-direction: column; gap: 1rem; }

  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .form-group label { font-size: 0.78rem; font-weight: 600; color: var(--ink-700); }
  .form-group label span { font-weight: 400; color: var(--ink-400); }
  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.7rem 0.875rem; border: 1px solid var(--ink-200);
    border-radius: var(--r); font-size: 0.875rem; color: var(--ink-900);
    font-family: var(--font); background: var(--white);
    transition: border-color var(--ease);
    outline: none;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus { border-color: #25D366; box-shadow: 0 0 0 3px rgba(37,211,102,0.12); }
  .form-group textarea { resize: vertical; min-height: 80px; }
  .form-group select { cursor: pointer; }

  .form-submit {
    display: flex; align-items: center; justify-content: center;
    gap: 0.6rem; width: 100%;
    background: #25D366 !important; border-color: #25D366 !important; color: #fff !important;
  }
  .form-submit:hover { background: #1ebe5d !important; border-color: #1ebe5d !important; }
  .form-submit svg { width: 20px; height: 20px; flex-shrink: 0; fill: #fff; }

  @media (max-width: 1024px) {
    .contact__layout { grid-template-columns: 1fr; gap: 3rem; }
  }
  @media (max-width: 768px) {
    .contact { padding: 3.5rem 0; }
    .form-row { grid-template-columns: 1fr; }
    .contact__form { padding: 1.5rem; }
    .contact__form-header { padding: 1rem 1.5rem; }
  }
  @media (max-width: 480px) {
    .contact__form { padding: 1.25rem 1rem; }
    .contact__form-header { padding: 0.85rem 1rem; }
    .contact__info { gap: 1.25rem; }
  }
</style>
