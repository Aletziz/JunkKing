---
const serviceLinks = [
  "Junk Removal", "Sod Installation", "Fast Delivery & Pickup",
  "Furniture Removal", "Appliance Removal", "Electronics Recycling",
  "Yard Waste Removal", "Full Space Cleanout",
];
const companyLinks = [
  { label: "How It Works", href: "#how-it-works" },
  { label: "Why Choose Us", href: "#why-us" },
  { label: "FAQ", href: "#faq" },
  { label: "Blog & Resources", href: "#resources" },
];
const areas = [
  "West Palm Beach", "Boca Raton", "Delray Beach", "Boynton Beach",
  "Wellington", "Jupiter", "Palm Beach Gardens", "Lake Worth",
];
---

<footer class="footer">

  <!-- Main footer grid -->
  <div class="footer__main">
    <div class="container footer__grid">

      <!-- Brand -->
      <div class="footer__brand">
        <a href="/" class="footer__logo">
          <img src="/logo.png" alt="AMG Junk Removal LLC" class="footer__logo-img" />
          <span>AMG Junk Removal <em>LLC</em></span>
        </a>
        <p class="footer__tagline">
          Palm Beach County's most trusted junk removal service.
          Fast, eco-friendly, and priced right.
        </p>
        <ul class="footer__contact-list">
          <li>
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M18 14.7v2.5a1.67 1.67 0 01-1.82 1.67A16.5 16.5 0 019.5 16.3a16.25 16.25 0 01-4.67-4.67 16.5 16.5 0 01-2.5-7.22A1.67 1.67 0 013.99 2.5H6.5a1.67 1.67 0 011.67 1.43c.1.8.3 1.59.58 2.35a1.67 1.67 0 01-.38 1.76l-1.07 1.07A13.34 13.34 0 0012.57 14l1.07-1.07a1.67 1.67 0 011.76-.38c.76.28 1.54.48 2.35.58A1.67 1.67 0 0118 14.7z"/>
            </svg>
            <a href="tel:+15617620065">(561) 762-0065</a>
          </li>
        </ul>
        <div class="footer__social">
          <a href="https://www.facebook.com/share/1EF19WmpxJ/?mibextid=wwXIfr" aria-label="Facebook" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a href="https://www.instagram.com/amgjunk?igsh=MWhobXdoeXc0bWV0MQ%3D%3D&utm_source=qr" aria-label="Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.5" y2="6.5" stroke-width="2.5" stroke-linecap="round"/></svg>
          </a>
          <a href="https://www.tiktok.com/@amg_junk_removal_?_r=1&_t=ZT-95BnLjIcq4r" aria-label="TikTok" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"/></svg>
          </a>
          <a href="https://wa.me/15617620065" aria-label="WhatsApp" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zm-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884zm8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div class="footer__col">
        <h4 class="footer__heading">Services</h4>
        <ul class="footer__links">
          {serviceLinks.map((s) => (
            <li><a href="#services">{s}</a></li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div class="footer__col">
        <h4 class="footer__heading">Company</h4>
        <ul class="footer__links">
          {companyLinks.map((l) => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Areas -->
      <div class="footer__col">
        <h4 class="footer__heading">Service Areas</h4>
        <ul class="footer__links">
          {areas.map((a) => (
            <li><a href="#areas">{a}</a></li>
          ))}
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <span>© {new Date().getFullYear()} AMG Junk Removal LLC. All rights reserved.</span>
      <div class="footer__legal">
        <a href="#">Privacy Policy</a>
        <span>·</span>
        <a href="#">Terms of Service</a>
        <span>·</span>
        <a href="#">Sitemap</a>
      </div>
    </div>
  </div>

</footer>

<style>
  .footer { background: var(--ink-900); color: rgba(255,255,255,0.55); }

  /* Main grid */
  .footer__main { padding: 5rem 0 4rem; }
  .footer__grid {
    display: grid; grid-template-columns: 1.8fr 1fr 1fr 1fr;
    gap: 3.5rem; align-items: start;
  }

  /* Brand */
  .footer__logo {
    display: flex; align-items: center; gap: 0.7rem;
    text-decoration: none; margin-bottom: 1.25rem;
  }
  .footer__logo-img { width: 48px; height: 48px; object-fit: contain; flex-shrink: 0; }
  .footer__logo span { font-size: 1rem; font-weight: 800; color: #fff; letter-spacing: -0.01em; }
  .footer__logo em { color: var(--red); font-style: normal; }
  .footer__tagline { font-size: 0.82rem; line-height: 1.7; margin-bottom: 1.5rem; max-width: 280px; }

  .footer__contact-list { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.5rem; }
  .footer__contact-list li { display: flex; align-items: center; gap: 0.55rem; font-size: 0.82rem; }
  .footer__contact-list svg { width: 14px; height: 14px; flex-shrink: 0; opacity: 0.5; }
  .footer__contact-list a { color: rgba(255,255,255,0.7); text-decoration: none; }
  .footer__contact-list a:hover { color: #fff; }

  .footer__social { display: flex; gap: 0.6rem; }
  .footer__social a {
    width: 32px; height: 32px; background: rgba(255,255,255,0.07);
    border-radius: var(--r); display: flex; align-items: center;
    justify-content: center; color: rgba(255,255,255,0.4);
    transition: all var(--ease);
  }
  .footer__social a:hover { background: rgba(255,255,255,0.13); color: #fff; }
  .footer__social svg { width: 14px; height: 14px; }

  /* Columns */
  .footer__heading {
    font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; color: rgba(255,255,255,0.35);
    margin-bottom: 1.25rem;
  }
  .footer__links { display: flex; flex-direction: column; gap: 0.6rem; }
  .footer__links li {}
  .footer__links a {
    font-size: 0.83rem; color: rgba(255,255,255,0.55); text-decoration: none;
    transition: color var(--ease);
  }
  .footer__links a:hover { color: #fff; }

  /* Bottom */
  .footer__bottom { padding: 1.5rem 0; }
  .footer__bottom-inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 1.5rem; flex-wrap: wrap;
    font-size: 0.78rem;
  }
  .footer__legal { display: flex; align-items: center; gap: 0.5rem; }
  .footer__legal a { color: rgba(255,255,255,0.4); text-decoration: none; transition: color var(--ease); }
  .footer__legal a:hover { color: rgba(255,255,255,0.75); }
  .footer__legal span { opacity: 0.25; }

  @media (max-width: 1024px) {
    .footer__grid { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
    .footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 640px) {
    .footer__grid { grid-template-columns: 1fr; }
    .footer__main { padding: 4rem 0 3rem; }
    .footer__bottom-inner { flex-direction: column; text-align: center; }
  }
</style>
