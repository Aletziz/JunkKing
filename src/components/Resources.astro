---
const posts = [
  {
    date: "Sep 08, 2025",
    category: "Tips & Guides",
    title: "How to Dispose of Concrete in Palm Beach County",
    excerpt: "Concrete disposal requires special handling. Learn the proper ways to remove and recycle concrete debris from your property in Palm Beach County without the headache.",
    readTime: "4 min read",
  },
  {
    date: "Sep 08, 2025",
    category: "Specialty Removal",
    title: "Boat Removal & Disposal in Palm Beach",
    excerpt: "Old boat taking up space? We break down everything you need to know about boat removal — from draining fluids to eco-friendly disposal options available locally.",
    readTime: "5 min read",
  },
  {
    date: "Sep 08, 2025",
    category: "Organization",
    title: "How to Declutter Before a Move",
    excerpt: "Moving is the perfect time to purge years of clutter. Our step-by-step guide helps you sort, donate, and schedule junk removal before your moving day arrives.",
    readTime: "6 min read",
  },
];
---

<section class="resources" id="resources">
  <div class="container">

    <div class="resources__header">
      <div>
        <span class="eyebrow">Resources</span>
        <div class="accent-line" style="margin: 0.6rem 0 1rem;"></div>
        <h2 class="h2" style="text-align:left;">Junk Removal Tips &amp; Guides</h2>
      </div>
      <a href="#resources" class="btn btn-outline resources__see-all">
        View All Articles
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="posts">
      {posts.map((p) => (
        <article class="post-card">
          <div class="post-card__img" aria-hidden="true">
            <svg viewBox="0 0 80 60" fill="none">
              <rect width="80" height="60" rx="6" fill="var(--ink-100)"/>
              <rect x="20" y="15" width="40" height="30" rx="3" fill="var(--ink-200)"/>
              <path d="M28 35l8-8 6 6 4-4 7 7" stroke="var(--ink-400)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="34" cy="26" r="3" fill="var(--ink-300)"/>
            </svg>
          </div>
          <div class="post-card__body">
            <div class="post-card__meta">
              <span class="post-card__cat">{p.category}</span>
              <span class="post-card__sep">·</span>
              <span class="post-card__date">{p.date}</span>
              <span class="post-card__sep">·</span>
              <span class="post-card__read">{p.readTime}</span>
            </div>
            <h3 class="post-card__title">{p.title}</h3>
            <p class="post-card__excerpt">{p.excerpt}</p>
            <a href="#resources" class="post-card__link">
              Read Article
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .resources { padding: 6rem 0; background: var(--white); }
  .resources__header {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 1.5rem; margin-bottom: 3rem; flex-wrap: wrap;
  }
  .resources__see-all {
    display: flex; align-items: center; gap: 0.5rem;
    white-space: nowrap; flex-shrink: 0;
  }
  .resources__see-all svg { width: 14px; height: 14px; transition: transform var(--ease); }
  .resources__see-all:hover svg { transform: translateX(3px); }

  .posts { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.25rem; }

  .post-card {
    background: var(--white); border: 1px solid var(--ink-200);
    border-radius: var(--r-xl); overflow: hidden;
    display: flex; flex-direction: column;
    transition: all var(--ease);
  }
  .post-card:hover { border-color: var(--red); box-shadow: var(--sh-md); transform: translateY(-3px); }

  .post-card__img {
    background: var(--ink-50); padding: 1.5rem;
    display: flex; align-items: center; justify-content: center;
    border-bottom: 1px solid var(--ink-100);
  }
  .post-card__img svg { width: 100%; max-width: 160px; height: auto; }

  .post-card__body { padding: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem; flex: 1; }

  .post-card__meta { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
  .post-card__cat  { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--red); }
  .post-card__sep  { font-size: 0.72rem; color: var(--ink-300); }
  .post-card__date { font-size: 0.72rem; color: var(--ink-400); }
  .post-card__read { font-size: 0.72rem; color: var(--ink-400); }

  .post-card__title {
    font-size: 0.95rem; font-weight: 700; color: var(--ink-900);
    line-height: 1.4; letter-spacing: -0.01em;
  }
  .post-card__excerpt { font-size: 0.82rem; color: var(--ink-500); line-height: 1.7; flex: 1; }

  .post-card__link {
    display: flex; align-items: center; gap: 0.4rem;
    font-size: 0.82rem; font-weight: 600; color: var(--red);
    text-decoration: none; margin-top: auto; transition: gap var(--ease);
  }
  .post-card__link svg { width: 14px; height: 14px; stroke: var(--red); transition: transform var(--ease); }
  .post-card__link:hover svg { transform: translateX(3px); }

  @media (max-width: 900px) { .posts { grid-template-columns: repeat(2,1fr); } }
  @media (max-width: 768px) {
    .resources { padding: 4rem 0; }
    .posts { grid-template-columns: 1fr; }
    .resources__header { align-items: flex-start; }
  }
</style>
