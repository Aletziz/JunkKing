---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = "AMG Junk Removal LLC | Junk Removal Services",
  description = "AMG Junk Removal LLC — Palm Beach County's #1 junk removal. Same-day appointments, free estimates, eco-friendly.",
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="preload" as="image" href="/team.jpg" fetchpriority="high" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <!-- Fix Google Translate layout injection (must load before body renders) -->
    <style>
      /* Kill GT banner & body offset */
      .goog-te-banner-frame,
      .goog-te-banner-frame.skiptranslate { display: none !important; visibility: hidden !important; }
      .skiptranslate > iframe              { display: none !important; height: 0 !important; }
      #goog-gt-tt, .goog-te-balloon-frame  { display: none !important; }
      body                                 { top: 0 !important; position: static !important; }
      /* Prevent the translated-ltr/rtl class from shifting anything */
      body.translated-ltr,
      body.translated-rtl                  { top: 0 !important; margin-top: 0 !important; }
    </style>
    <script is:inline>
      // MutationObserver: undo body.style.top whenever GT sets it
      (function () {
        var mo = new MutationObserver(function () {
          if (document.body && document.body.style.top && document.body.style.top !== '0px') {
            document.body.style.top = '0px';
          }
        });
        document.addEventListener('DOMContentLoaded', function () {
          mo.observe(document.body, { attributes: true, attributeFilter: ['style', 'class'] });
        });
      })();
    </script>
  </head>
  <body>
    <slot />
    <script is:inline>
      (function () {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

        function observe() {
          document.querySelectorAll('.reveal, .reveal-group').forEach(function (el) {
            io.observe(el);
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', observe);
        } else {
          observe();
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    --red:        #00C8C8;
    --red-dark:   #00a0a0;
    --red-sub:    rgba(0,200,200,0.08);
    --ink-900:    #000A1A;
    --ink-800:    #0d1526;
    --ink-700:    #2c3140;
    --ink-600:    #454c5e;
    --ink-500:    #6b7280;
    --ink-400:    #9ca3af;
    --ink-300:    #d1d5db;
    --ink-200:    #e8eaed;
    --ink-100:    #f3f4f6;
    --ink-50:     #f9fafb;
    --white:      #ffffff;
    --font:       "Inter", system-ui, sans-serif;
    --w:          1160px;
    --r:          8px;
    --r-lg:       14px;
    --r-xl:       20px;
    --ease:       0.18s ease;
    --sh-sm:      0 1px 4px rgba(0,0,0,0.07);
    --sh-md:      0 4px 18px rgba(0,0,0,0.09);
    --sh-lg:      0 16px 48px rgba(0,0,0,0.12);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html  { scroll-behavior: smooth; }
  body  {
    font-family: var(--font);
    color: var(--ink-600);
    background: var(--white);
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }
  img   { max-width: 100%; height: auto; display: block; }
  a     { color: inherit; text-decoration: none; }
  ul    { list-style: none; }
  button, input, select, textarea { font-family: var(--font); }
  button { cursor: pointer; }

  /* Container */
  .container { max-width: var(--w); margin: 0 auto; padding: 0 1.5rem; }

  /* Buttons */
  .btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 0.45rem; padding: 0.68rem 1.5rem;
    border-radius: var(--r); font-weight: 600; font-size: 0.875rem;
    letter-spacing: 0.01em; transition: all var(--ease);
    border: 1.5px solid transparent; white-space: nowrap; line-height: 1;
    cursor: pointer;
  }
  .btn:hover { transform: translateY(-1px); }
  .btn svg   { width: 15px; height: 15px; flex-shrink: 0; }

  .btn-primary  { background: var(--red); color: var(--ink-900); border-color: var(--red); }
  .btn-primary:hover  { background: var(--red-dark); border-color: var(--red-dark); box-shadow: 0 4px 16px rgba(0,200,200,0.28); }

  .btn-outline  { background: transparent; color: var(--red); border-color: var(--red); }
  .btn-outline:hover  { background: var(--red); color: var(--ink-900); }

  .btn-ghost    { background: rgba(255,255,255,0.06); color: #fff; border-color: rgba(255,255,255,0.14); }
  .btn-ghost:hover    { background: rgba(255,255,255,0.12); }

  .btn-white    { background: #fff; color: var(--ink-900); border-color: #fff; }
  .btn-white:hover    { background: var(--ink-100); }

  .btn-lg { padding: 0.82rem 1.9rem; font-size: 0.92rem; }

  /* Typography helpers */
  .eyebrow {
    display: block; font-size: 0.68rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.14em;
    color: var(--red); margin-bottom: 0.75rem;
  }
  .h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800;
    color: var(--ink-900); line-height: 1.18; letter-spacing: -0.02em;
    margin-bottom: 0.85rem;
  }
  .lead {
    font-size: 0.975rem; color: var(--ink-500); line-height: 1.72;
    max-width: 540px;
  }

  /* ── Scroll reveal animations ── */
  .reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.6s cubic-bezier(.4,0,.2,1), transform 0.6s cubic-bezier(.4,0,.2,1);
  }
  .reveal.reveal--left  { transform: translateX(-40px); }
  .reveal.reveal--right { transform: translateX(40px); }
  .reveal.reveal--scale { transform: scale(0.93) translateY(18px); }
  .reveal.is-visible {
    opacity: 1;
    transform: none;
  }
  /* Stagger siblings inside a reveal-group */
  .reveal-group > * {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.55s cubic-bezier(.4,0,.2,1), transform 0.55s cubic-bezier(.4,0,.2,1);
  }
  .reveal-group.is-visible > *:nth-child(1) { opacity:1; transform:none; transition-delay: 0s; }
  .reveal-group.is-visible > *:nth-child(2) { opacity:1; transform:none; transition-delay: 0.1s; }
  .reveal-group.is-visible > *:nth-child(3) { opacity:1; transform:none; transition-delay: 0.2s; }
  .reveal-group.is-visible > *:nth-child(4) { opacity:1; transform:none; transition-delay: 0.3s; }
  .reveal-group.is-visible > *:nth-child(5) { opacity:1; transform:none; transition-delay: 0.4s; }
  .reveal-group.is-visible > *:nth-child(6) { opacity:1; transform:none; transition-delay: 0.5s; }

  /* Reduce motion for accessibility */
  @media (prefers-reduced-motion: reduce) {
    .reveal, .reveal-group > * { transition: none !important; opacity: 1 !important; transform: none !important; }
  }

  .tc  { text-align: center; }
  .tc .lead { margin: 0 auto; }
  .accent-line {
    width: 36px; height: 3px; background: var(--red);
    border-radius: 2px; margin-bottom: 1.25rem;
  }
  .tc .accent-line { margin: 0 auto 1.25rem; }
</style>
