---
---
<section class="hero" id="home">
  <div class="hero__bg"></div>

  <!-- Imagen posicionada absolutamente: cubre la mitad derecha hasta el borde de pantalla -->
  <div class="truck-scene" aria-hidden="true">
    <img src="/team.jpg"
         class="truck-scene__img"
         alt="AMG Junk Removal LLC — Our Team"
         loading="eager"
         fetchpriority="high"
         decoding="async"
         width="1400"
         height="933"
    />
    <div class="truck-scene__overlay"></div>
    <div class="truck-scene__chips">
      <span class="chip">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M1 2h4l1.5 7.5h7l1.5-5H4"/><circle cx="6" cy="13" r="1.2"/><circle cx="12" cy="13" r="1.2"/></svg>
        Junk Removal
      </span>
      <span class="chip">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="1" y="9" width="14" height="4" rx="0.8"/><path d="M3 9V6M6 9V5M9 9V7M12 9V6"/></svg>
        Sod Installation
      </span>
      <span class="chip">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="1" y="4" width="10" height="7" rx="0.8"/><path d="M11 6.5h2.5l2 2V11h-4.5V6.5z"/><circle cx="3.5" cy="12.5" r="1.3"/><circle cx="12.5" cy="12.5" r="1.3"/></svg>
        Fast Delivery
      </span>
      <span class="chip">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M8 2v4l2.5 2.5"/><circle cx="8" cy="8" r="6"/></svg>
        Same-day pickup
      </span>
    </div>
  </div>

  <div class="container hero__inner">
    <div class="hero__content">
      <h1 class="hero__title">
        Palm Beach's #1<br/><span class="hero__accent">Junk Removal</span><br/>Service
      </h1>
      <p class="hero__desc">
        Junk removal, sod installation and same-day delivery &amp; pickup.
        Free estimates, eco-friendly disposal — up to 60% recycled or donated.
      </p>
      <div class="hero__cta">
        <a href="tel:+15617620065" class="btn btn-primary btn-lg">
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 3.5A1.5 1.5 0 013.5 2h1.148a1 1 0 01.95.684l.93 2.8a1 1 0 01-.23 1.02L5.1 7.7a11.04 11.04 0 005.2 5.2l1.196-1.198a1 1 0 011.02-.23l2.8.93A1 1 0 0116 13.35v1.15A1.5 1.5 0 0114.5 16C7.596 16 2 10.404 2 3.5z"/></svg>
          (561) 762-0065
        </a>
        <a href="sms:+15617620065" class="btn btn-ghost btn-lg">
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 4a2 2 0 012-2h12a2 2 0 012 2v9a2 2 0 01-2 2H6l-4 3V4z" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Text Us
        </a>
      </div>

      <div class="hero__stats">
        <div class="stat">
          <span class="stat__n">Same&nbsp;Day</span>
          <span class="stat__l">Appointments</span>
        </div>
        <div class="stat__div"></div>
        <div class="stat">
          <span class="stat__n">60%</span>
          <span class="stat__l">Recycled / Donated</span>
        </div>
        <div class="stat__div"></div>
        <div class="stat">
          <span class="stat__n">Free</span>
          <span class="stat__l">Estimates</span>
        </div>
      </div>
    </div>
  </div>

</section>

<style>
  .hero {
    position: relative;
    background: var(--ink-900);
    padding: 7rem 0 0;
    overflow: hidden;
  }
  .hero__bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 35% 45% at 5%  85%, rgba(0,10,26,0.8) 0%, transparent 70%);
  }

  /* ── IMAGEN: posición absoluta, mitad derecha, borde real de pantalla ── */
  .truck-scene {
    position: absolute;
    top: 0; right: 0;
    width: 75%;
    height: 100%;
    z-index: 0;
  }
  .truck-scene__img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: 55% center;
    display: block;
    filter: brightness(0.72) saturate(0.85);
  }
  /* Fade izquierdo: solo los primeros ~8% del truck-scene se disuelven */
  .truck-scene__overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(to right, rgba(0,10,26,1) 0%, rgba(0,10,26,0.7) 4%, rgba(0,10,26,0.0) 12%, transparent 100%),
      linear-gradient(to top,   rgba(0,10,26,0.8) 0%, transparent 35%);
    pointer-events: none;
  }
  /* Chips flotantes en esquina inferior derecha de la imagen */
  .truck-scene__chips {
    position: absolute;
    bottom: 5rem; right: 2rem;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 0.5rem; width: 260px;
  }

  /* ── LAYOUT CONTENIDO ── */
  .hero__inner {
    position: relative; z-index: 1;
    display: flex;
    padding-top: 1rem; padding-bottom: 5rem;
    min-height: 600px;
    align-items: center;
  }
  .hero__content {
    display: flex; flex-direction: column; justify-content: center;
    width: 100%;
    max-width: 420px;
  }

  /* Badge */
  .hero__badge {
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: rgba(251,191,36,0.12); border: 1px solid rgba(251,191,36,0.25);
    color: #fbbf24; font-size: 0.78rem; font-weight: 600;
    padding: 0.35rem 0.85rem; border-radius: 100px; margin-bottom: 1.25rem;
  }
  .hero__badge svg { width: 13px; height: 13px; }

  .hero__title {
    font-size: clamp(1.75rem, 4.5vw, 3.2rem); font-weight: 900;
    color: #fff; line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 1rem;
    word-break: break-word; overflow-wrap: break-word;
    text-shadow:
      0 0 30px rgba(0,0,0,0.9),
      0 2px 8px  rgba(0,0,0,0.8),
      0 0  4px  rgba(0,0,0,0.6);
  }
  .hero__accent { color: var(--red); }

  .hero__desc {
    font-size: 0.95rem; color: rgba(255,255,255,0.85);
    max-width: 400px; margin-bottom: 2rem; line-height: 1.7;
    word-break: break-word; overflow-wrap: break-word;
    text-shadow:
      0 0 20px rgba(0,0,0,0.95),
      0 1px 6px rgba(0,0,0,0.8);
  }

  .hero__cta { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
  .hero__cta .btn-ghost { background: rgba(255,255,255,0.07); color: #fff; border-color: rgba(255,255,255,0.18); }
  .hero__cta .btn-ghost:hover { background: rgba(255,255,255,0.13); }
  /* Allow translated button labels to wrap gracefully */
  .hero__cta .btn { white-space: normal; text-align: center; min-width: 0; }

  .hero__stats {
    display: flex; align-items: stretch;
    background: rgba(0,10,26,0.55); border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border-radius: var(--r-lg); padding: 0.9rem 1.25rem;
    width: 100%; max-width: 420px; flex-wrap: wrap; gap: 0.5rem 0;
  }
  .stat { display: flex; flex-direction: column; align-items: center; padding: 0 0.75rem; flex: 1; min-width: 0; }
  .stat:first-child { padding-left: 0; }
  .stat__n { font-size: 1.1rem; font-weight: 900; color: var(--red); line-height: 1; }
  /* Allow stat labels to wrap — no nowrap */
  .stat__l {
    font-size: 0.62rem; color: rgba(255,255,255,0.65); font-weight: 500;
    text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.2rem;
    text-align: center; word-break: break-word; hyphens: auto;
  }
  .stat__div { width: 1px; background: rgba(255,255,255,0.12); flex-shrink: 0; align-self: stretch; min-height: 28px; }

  /* Chips — allow wrap on translation */
  .chip {
    display: flex; align-items: center; gap: 0.4rem;
    background: rgba(0,10,26,0.6); border: 1px solid rgba(255,255,255,0.12);
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    border-radius: var(--r); padding: 0.5rem 0.7rem;
    font-size: 0.72rem; color: rgba(255,255,255,0.85); font-weight: 500;
    white-space: normal; word-break: break-word;
  }
  .chip svg { width: 13px; height: 13px; stroke: var(--red); flex-shrink: 0; }

  /* Offer bar */
  .offer-bar { position: relative; z-index: 2; background: var(--red); padding: 0.7rem 0; }
  .offer-bar__inner {
    display: flex; align-items: center; gap: 0.75rem;
    font-size: 0.83rem; font-weight: 500; color: rgba(0,0,0,0.75);
    flex-wrap: wrap;
  }
  .offer-bar__icon { width: 16px; height: 16px; stroke: rgba(0,0,0,0.55); flex-shrink: 0; }
  .offer-bar__inner strong { color: var(--ink-900); font-weight: 700; }
  .offer-bar__sep  { opacity: 0.35; }
  .offer-bar__exp  { opacity: 0.6; font-size: 0.78rem; }
  .offer-bar__cta  {
    margin-left: auto; background: rgba(0,0,0,0.12); color: var(--ink-900);
    border: 1px solid rgba(0,0,0,0.2); border-radius: var(--r);
    padding: 0.35rem 1rem; font-size: 0.78rem; font-weight: 700;
    transition: background var(--ease);
  }
  .offer-bar__cta:hover { background: rgba(0,0,0,0.22); }

  @media (max-width: 900px) {
    .hero { padding: 5rem 0 0; }
    .truck-scene {
      position: relative;
      width: 100%; height: 260px;
      top: unset; right: unset;
    }
    .truck-scene__img {
      filter: brightness(0.88) saturate(1.05);
    }
    .truck-scene__overlay {
      background:
        linear-gradient(to bottom, transparent 40%, rgba(0,10,26,0.55) 100%);
    }
    .truck-scene__chips { display: none; }
    .hero__inner {
      grid-template-columns: 1fr;
      min-height: unset;
      padding-top: 2rem; padding-bottom: 3rem;
    }
    .hero__content { max-width: 100%; }
  }
  @media (max-width: 480px) {
    .truck-scene { height: 200px; }
    .hero__cta { flex-direction: column; }
    .hero__stats { width: 100%; justify-content: space-around; }
    .offer-bar__cta { margin-left: 0; width: 100%; text-align: center; }
  }
</style>
