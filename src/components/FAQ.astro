---
const faqs = [
  {
    q: "What services do you offer?",
    a: "We offer junk removal, sod installation, and fast delivery & pickup throughout Palm Beach County. Whether it's hauling old furniture, laying fresh sod, or delivering materials same-day — our crew handles it all.",
  },
  {
    q: "How much does junk removal cost?",
    a: "Pricing is based on volume — how much space your items take up in the truck. We provide an upfront quote on-site before any work begins. No surprises. We'll also beat any written competitor estimate.",
  },
  {
    q: "Do you offer same-day service?",
    a: "Yes! We offer same-day appointments for junk removal, sod installation, and delivery & pickup. Call us or book online and we'll confirm your slot fast.",
  },
  {
    q: "How does sod installation work?",
    a: "We arrive, prep the ground, and lay fresh sod — all in one visit. We handle residential and commercial properties of any size. Just give us a call for a free estimate and we'll take care of the rest.",
  },
  {
    q: "Which areas do you serve?",
    a: "We serve all of Palm Beach County including West Palm Beach, Boca Raton, Delray Beach, Boynton Beach, Wellington, Jupiter, Palm Beach Gardens, Lake Worth, and surrounding areas.",
  },
  {
    q: "How is junk removal pricing determined?",
    a: "We price based on the volume of space your junk occupies in our truck — not per item, not by weight. We give you a firm quote on-site before starting any work.",
  },
];
---

<section class="faq" id="faq">
  <div class="container">
    <div class="faq__layout">

      <!-- Left column -->
      <div class="faq__sidebar">
        <span class="eyebrow" style="color:#000A1A;">FAQ</span>
        <div class="accent-line" style="margin: 0.6rem 0 1rem;"></div>
        <h2 class="h2" style="text-align:left;">Frequently Asked Questions</h2>
        <p style="font-size:0.9rem;color:var(--ink-500);line-height:1.7;margin-top:1rem;">
          Have a question not listed here? Our team is always happy to help.
        </p>
        <div class="faq__contact-links">
          <a href="tel:+15612466352" class="faq__link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.5 19.79 19.79 0 01.02 2.84 2 2 0 012 .67h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.49a16 16 0 006.29 6.29l1.1-1.1a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            (561) 246-6352
          </a>
          <a href="#contact" class="faq__link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
            </svg>
            Contact Form
          </a>
        </div>
      </div>

      <!-- Accordion -->
      <div class="faq__accordion">
        {faqs.map((item, i) => (
          <details class="faq__item" name="faq">
            <summary class="faq__question">
              <span class="faq__q-text">{item.q}</span>
              <span class="faq__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </summary>
            <div class="faq__answer">
              <p>{item.a}</p>
            </div>
          </details>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .faq { padding: 6rem 0; background: var(--ink-50); }
  .faq__layout {
    display: grid; grid-template-columns: 320px 1fr;
    gap: 5rem; align-items: start;
  }

  /* Sidebar */
  .faq__contact-links { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 2rem; }
  .faq__link {
    display: flex; align-items: center; gap: 0.65rem;
    font-size: 0.88rem; font-weight: 600; color: var(--ink-700);
    text-decoration: none; padding: 0.75rem 1rem;
    border: 1px solid var(--ink-200); border-radius: var(--r);
    background: var(--white); transition: all var(--ease);
  }
  .faq__link:hover { border-color: #000A1A; color: #000A1A; }
  .faq__link svg { width: 16px; height: 16px; flex-shrink: 0; }

  /* Accordion */
  .faq__accordion { display: flex; flex-direction: column; gap: 0; }
  .faq__item {
    border-bottom: 1px solid var(--ink-200);
  }
  .faq__item:first-child { border-top: 1px solid var(--ink-200); }
  .faq__item[open] .faq__icon svg { transform: rotate(180deg); }

  .faq__question {
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem; padding: 1.35rem 0; cursor: pointer;
    list-style: none; transition: color var(--ease);
  }
  .faq__question::-webkit-details-marker { display: none; }
  .faq__question:hover .faq__q-text { color: #000A1A; }

  .faq__q-text { font-size: 0.92rem; font-weight: 600; color: var(--ink-900); line-height: 1.4; }
  .faq__icon { width: 28px; height: 28px; border: 1px solid var(--ink-200); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .faq__icon svg { width: 14px; height: 14px; stroke: var(--ink-500); transition: transform 0.2s ease; }
  .faq__item[open] .faq__icon { border-color: #000A1A; background: rgba(0,10,26,0.05); }
  .faq__item[open] .faq__icon svg { stroke: #000A1A; }

  .faq__answer { padding: 0 0 1.25rem; }
  .faq__answer p { font-size: 0.86rem; color: var(--ink-600); line-height: 1.75; max-width: 540px; }

  @media (max-width: 900px) {
    .faq__layout { grid-template-columns: 1fr; gap: 2.5rem; }
    .faq__sidebar { max-width: 480px; }
  }
  @media (max-width: 768px) { .faq { padding: 4rem 0; } }
</style>
