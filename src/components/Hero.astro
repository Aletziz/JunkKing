---
---
<section class="hero" id="home">
  <div class="hero__bg"></div>

  <!-- Imagen posicionada absolutamente: cubre la mitad derecha hasta el borde de pantalla -->
  <div class="truck-scene" aria-hidden="true">
    <img src="/truck.jpeg" class="truck-scene__img" alt="AMG Junk Removal LLC — King-Size Truck" />
    <div class="truck-scene__overlay"></div>
    <div class="truck-scene__chips">
      <span class="chip">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M8 2v4l2.5 2.5"/><circle cx="8" cy="8" r="6"/></svg>
        Same-day pickup
      </span>
      <span class="chip">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 8l2 2 4-4"/><circle cx="8" cy="8" r="6"/></svg>
        Free estimate
      </span>
      <span class="chip">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 8.5C4 5.5 12 2 12 2s-3 7.5-6 9a2.5 2.5 0 01-2-2.5z"/></svg>
        Eco-friendly
      </span>
      <span class="chip">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 9l2.5-5L8 7l2-4 2.5 5" stroke-linecap="round"/><path d="M1 12h14"/></svg>
        Beat any quote
      </span>
    </div>
  </div>

  <div class="container hero__inner">
    <div class="hero__content">
      <div class="hero__badge">
        <svg viewBox="0 0 16 16" fill="#fbbf24"><path d="M8 1l1.545 4.753H14.9l-4.228 3.073 1.617 4.97L8 11.01l-4.29 2.787 1.617-4.97L1.1 5.753h5.355z"/></svg>
        <span>983+ Reviews · 5/5 Rating</span>
      </div>
      <h1 class="hero__title">
        Palm Beach's #1<br/><span class="hero__accent">Junk Removal</span><br/>Service
      </h1>
      <p class="hero__desc">
        Same-day appointments, free estimates, and we do all the heavy lifting.
        Eco-friendly disposal — up to 60% recycled or donated.
      </p>
      <div class="hero__cta">
        <a href="#contact" class="btn btn-primary btn-lg">
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="4" width="14" height="13" rx="1.5"/><path d="M14 2v4M6 2v4M3 9h14"/></svg>
          Book Online — Save $20
        </a>
        <a href="tel:5612466352" class="btn btn-ghost btn-lg">
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 3.5A1.5 1.5 0 013.5 2h1.148a1 1 0 01.95.684l.93 2.8a1 1 0 01-.23 1.02L5.1 7.7a11.04 11.04 0 005.2 5.2l1.196-1.198a1 1 0 011.02-.23l2.8.93A1 1 0 0116 13.35v1.15A1.5 1.5 0 0114.5 16C7.596 16 2 10.404 2 3.5z"/></svg>
          (561) 246-6352
        </a>
      </div>

      <div class="hero__stats">
        <div class="stat">
          <span class="stat__n">983+</span>
          <span class="stat__l">5-Star Reviews</span>
        </div>
        <div class="stat__div"></div>
        <div class="stat">
          <span class="stat__n">60%</span>
          <span class="stat__l">Recycled / Donated</span>
        </div>
        <div class="stat__div"></div>
        <div class="stat">
          <span class="stat__n">Same&nbsp;Day</span>
          <span class="stat__l">Appointments</span>
        </div>
        <div class="stat__div"></div>
        <div class="stat">
          <span class="stat__n">Free</span>
          <span class="stat__l">Estimates</span>
        </div>
      </div>
    </div>
  </div>

  <div class="offer-bar">
    <div class="container offer-bar__inner">
      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" class="offer-bar__icon"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
      <strong>Special Offer:</strong>
      <span>$20 OFF when booking online</span>
      <span class="offer-bar__sep">·</span>
      <span class="offer-bar__exp">Expires Sep 30, 2026</span>
      <a href="#contact" class="offer-bar__cta">Claim Now</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--ink-900);
    padding: 7rem 0 0;
    overflow: hidden;
  }
  .hero__bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 55% 65% at 95% 45%, rgba(0,247,247,0.10) 0%, transparent 65%),
      radial-gradient(ellipse 35% 45% at 5%  85%, rgba(0,10,26,0.8)    0%, transparent 70%);
  }

  /* ── IMAGEN: posición absoluta, mitad derecha, borde real de pantalla ── */
  .truck-scene {
    position: absolute;
    top: 0; right: 0;
    width: 52%;
    height: 100%;
    z-index: 0;
  }
  .truck-scene__img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 35%;
    display: block;
    filter: brightness(0.72) saturate(0.85);
  }
  /* Fade izquierdo: imagen se disuelve hacia el fondo oscuro */
  .truck-scene__overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(to right,  rgba(0,10,26,1) 0%, rgba(0,10,26,0.55) 6%, rgba(0,10,26,0.08) 18%, transparent 100%),
      linear-gradient(to top,    rgba(0,10,26,0.85) 0%, transparent 40%);
    pointer-events: none;
  }
  /* Chips flotantes en esquina inferior derecha de la imagen */
  .truck-scene__chips {
    position: absolute;
    bottom: 5rem; right: 2rem;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 0.5rem; width: 260px;
  }

  /* ── LAYOUT CONTENIDO ── */
  .hero__inner {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 1fr 1fr;
    padding-top: 1rem; padding-bottom: 5rem;
    min-height: 600px;
    align-items: center;
  }
  .hero__content {
    display: flex; flex-direction: column; justify-content: center;
    max-width: 560px;
  }

  /* Badge */
  .hero__badge {
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: rgba(251,191,36,0.12); border: 1px solid rgba(251,191,36,0.25);
    color: #fbbf24; font-size: 0.78rem; font-weight: 600;
    padding: 0.35rem 0.85rem; border-radius: 100px; margin-bottom: 1.5rem;
  }
  .hero__badge svg { width: 13px; height: 13px; }

  .hero__title {
    font-size: clamp(2.2rem, 5vw, 3.5rem); font-weight: 900;
    color: #fff; line-height: 1.08; letter-spacing: -0.03em; margin-bottom: 1.25rem;
  }
  .hero__accent { color: var(--red); }

  .hero__desc { font-size: 1rem; color: rgba(255,255,255,0.65); max-width: 460px; margin-bottom: 2.25rem; line-height: 1.7; }

  .hero__cta { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 3rem; }
  .hero__cta .btn-ghost { background: rgba(255,255,255,0.07); color: #fff; border-color: rgba(255,255,255,0.18); }
  .hero__cta .btn-ghost:hover { background: rgba(255,255,255,0.13); }

  .hero__stats {
    display: flex; align-items: center;
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.09);
    border-radius: var(--r-lg); padding: 1.1rem 1.5rem;
    width: fit-content; flex-wrap: wrap; gap: 0;
  }
  .stat { display: flex; flex-direction: column; align-items: center; padding: 0 1.25rem; }
  .stat:first-child { padding-left: 0; }
  .stat__n { font-size: 1.35rem; font-weight: 900; color: var(--red); line-height: 1; }
  .stat__l { font-size: 0.68rem; color: rgba(255,255,255,0.5); font-weight: 500; text-transform: uppercase; letter-spacing: 0.06em; margin-top: 0.25rem; white-space: nowrap; }
  .stat__div { width: 1px; height: 32px; background: rgba(255,255,255,0.12); flex-shrink: 0; }

  /* Chips */
  .chip {
    display: flex; align-items: center; gap: 0.5rem;
    background: rgba(0,10,26,0.6); border: 1px solid rgba(255,255,255,0.12);
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    border-radius: var(--r); padding: 0.55rem 0.8rem;
    font-size: 0.75rem; color: rgba(255,255,255,0.85); font-weight: 500;
    white-space: nowrap;
  }
  .chip svg { width: 13px; height: 13px; stroke: var(--red); flex-shrink: 0; }

  /* Offer bar */
  .offer-bar { position: relative; z-index: 2; background: var(--red); padding: 0.7rem 0; }
  .offer-bar__inner {
    display: flex; align-items: center; gap: 0.75rem;
    font-size: 0.83rem; font-weight: 500; color: rgba(0,0,0,0.75);
    flex-wrap: wrap;
  }
  .offer-bar__icon { width: 16px; height: 16px; stroke: rgba(0,0,0,0.55); flex-shrink: 0; }
  .offer-bar__inner strong { color: var(--ink-900); font-weight: 700; }
  .offer-bar__sep  { opacity: 0.35; }
  .offer-bar__exp  { opacity: 0.6; font-size: 0.78rem; }
  .offer-bar__cta  {
    margin-left: auto; background: rgba(0,0,0,0.12); color: var(--ink-900);
    border: 1px solid rgba(0,0,0,0.2); border-radius: var(--r);
    padding: 0.35rem 1rem; font-size: 0.78rem; font-weight: 700;
    transition: background var(--ease);
  }
  .offer-bar__cta:hover { background: rgba(0,0,0,0.22); }

  @media (max-width: 900px) {
    .hero { padding: 5rem 0 0; }
    .truck-scene {
      position: relative;
      width: 100%; height: 260px;
      top: unset; right: unset;
    }
    .truck-scene__overlay {
      background:
        linear-gradient(to bottom, transparent 30%, rgba(0,10,26,0.9) 100%),
        linear-gradient(to top,    rgba(0,10,26,0.6) 0%, transparent 50%);
    }
    .truck-scene__chips { display: none; }
    .hero__inner {
      grid-template-columns: 1fr;
      min-height: unset;
      padding-top: 2rem; padding-bottom: 3rem;
    }
    .hero__content { max-width: 100%; }
  }
  @media (max-width: 480px) {
    .truck-scene { height: 200px; }
    .hero__cta { flex-direction: column; }
    .hero__stats { width: 100%; justify-content: space-around; }
    .offer-bar__cta { margin-left: 0; width: 100%; text-align: center; }
  }
</style>
