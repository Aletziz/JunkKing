---
const blogPosts = [
  {
    title: "Palm Beach Concrete Disposal and Recycling",
    desc: "Crews are scrambling to make repairs to the ailing Memorial Fountain in the Town Hall Square. Learn about concrete disposal options in Palm Beach...",
    date: "Sep 08, 2025",
    emoji: "🏗️",
  },
  {
    title: "Boat Removal - Yes, We Do That Too!",
    desc: "Last week we removed an old boat from a customer's property. For a long time, his view had been clouded by this old, abandoned boat...",
    date: "Sep 08, 2025",
    emoji: "⛵",
  },
  {
    title: "How to Declutter Your Home Before a Move",
    desc: "Moving is the perfect time to get rid of items you no longer need. Here's how Junk King can make your move-out cleanout stress-free...",
    date: "Aug 15, 2025",
    emoji: "📦",
  },
];
---

<section class="resources" id="resources">
  <div class="container">
    <div class="text-center section-header">
      <span class="section-tag">Helpful Resources</span>
      <h2 class="section-title">Latest from Our Blog</h2>
      <p class="section-subtitle">
        Get the most out of Junk King Palm Beach with our insightful blog posts —
        junk removal tips, industry insights, and helpful information.
      </p>
    </div>

    <div class="blog-grid">
      {blogPosts.map((post) => (
        <article class="blog-card">
          <div class="blog-emoji">{post.emoji}</div>
          <div class="blog-content">
            <span class="blog-date">{post.date}</span>
            <h3 class="blog-title">{post.title}</h3>
            <p class="blog-desc">{post.desc}</p>
            <a href="https://www.junk-king.com/locations/palmbeach/blog/article" target="_blank" rel="noopener" class="blog-link">
              Learn More →
            </a>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center" style="margin-top: 3rem;">
      <a href="https://www.junk-king.com/locations/palmbeach/blog/article" target="_blank" rel="noopener" class="btn btn-outline">
        View All Resources →
      </a>
    </div>
  </div>
</section>

<style>
  .resources {
    padding: 6rem 0;
    background: var(--color-white);
  }

  .section-header {
    margin-bottom: 3.5rem;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .blog-card {
    background: var(--color-gray-50);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-gray-200);
    transition: all var(--transition);
    display: flex;
    flex-direction: column;
  }

  .blog-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
    border-color: var(--color-primary);
  }

  .blog-emoji {
    background: var(--color-gray-900);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    padding: 2.5rem;
  }

  .blog-content {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .blog-date {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .blog-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-gray-900);
    line-height: 1.4;
  }

  .blog-desc {
    font-size: 0.875rem;
    color: var(--color-gray-500);
    line-height: 1.6;
    flex: 1;
  }

  .blog-link {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-top: auto;
    transition: gap var(--transition);
  }

  .blog-link:hover {
    letter-spacing: 0.02em;
  }

  @media (max-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .resources {
      padding: 4rem 0;
    }

    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
