---
const faqs = [
  {
    q: "Do you accept all brands of dumpster bags?",
    a: "Yes — we pick up any brand of dumpster bag (Bagster, CLEAN OUT, Clean Earth, etc.) from anywhere on your property. Just fill it at your own pace and schedule pickup when ready.",
  },
  {
    q: "How much does sofa or couch removal cost?",
    a: "Pricing is based on volume — how much space your items take up in the truck. A standard sofa typically runs $75–$150. We provide an upfront quote before any work begins. No surprises.",
  },
  {
    q: "Does a refrigerator need to be empty for removal?",
    a: "Yes, please empty and defrost your refrigerator before our crew arrives. We can handle most appliances, but food inside can create sanitation issues and additional charges.",
  },
  {
    q: "Do you disassemble hot tubs before removal?",
    a: "Absolutely. Our crew will disassemble the hot tub on-site and remove all components, including the shell, base, and any equipment. We handle everything so you don't have to.",
  },
  {
    q: "Which areas do you serve?",
    a: "We serve all of Palm Beach County including West Palm Beach, Boca Raton, Delray Beach, Boynton Beach, Wellington, Jupiter, Palm Beach Gardens, Lake Worth, and surrounding areas.",
  },
  {
    q: "How is pricing determined?",
    a: "We price based on the volume of space your junk occupies in our truck — not per item, not by weight. We give you a firm quote on-site before starting any work. We'll also beat any written competitor estimate.",
  },
];
---

<section class="faq" id="faq">
  <div class="container">
    <div class="faq__layout">

      <!-- Left column -->
      <div class="faq__sidebar">
        <span class="eyebrow" style="color:var(--red);">FAQ</span>
        <div class="accent-line" style="margin: 0.6rem 0 1rem;"></div>
        <h2 class="h2" style="text-align:left;color:#fff;">Frequently Asked Questions</h2>
        <p style="font-size:0.9rem;color:rgba(255,255,255,0.5);line-height:1.7;margin-top:1rem;">
          Have a question not listed here? Our team is always happy to help.
        </p>
        <div class="faq__contact-links">
          <a href="tel:+15612466352" class="faq__link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.5 19.79 19.79 0 01.02 2.84 2 2 0 012 .67h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.49a16 16 0 006.29 6.29l1.1-1.1a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            (561) 246-6352
          </a>
          <a href="#contact" class="faq__link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
            </svg>
            Contact Form
          </a>
        </div>
      </div>

      <!-- Accordion -->
      <div class="faq__accordion">
        {faqs.map((item, i) => (
          <details class="faq__item" name="faq">
            <summary class="faq__question">
              <span class="faq__q-text">{item.q}</span>
              <span class="faq__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </summary>
            <div class="faq__answer">
              <p>{item.a}</p>
            </div>
          </details>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .faq { padding: 6rem 0; background: #000A1A; }
  .faq__layout {
    display: grid; grid-template-columns: 320px 1fr;
    gap: 5rem; align-items: start;
  }

  /* Sidebar */
  .faq__contact-links { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 2rem; }
  .faq__link {
    display: flex; align-items: center; gap: 0.65rem;
    font-size: 0.88rem; font-weight: 600; color: rgba(255,255,255,0.7);
    text-decoration: none; padding: 0.75rem 1rem;
    border: 1px solid rgba(255,255,255,0.1); border-radius: var(--r);
    background: rgba(255,255,255,0.04); transition: all var(--ease);
  }
  .faq__link:hover { border-color: var(--red); color: var(--red); background: rgba(0,247,247,0.05); }
  .faq__link svg { width: 16px; height: 16px; flex-shrink: 0; }

  /* Accordion */
  .faq__accordion { display: flex; flex-direction: column; gap: 0; }
  .faq__item {
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .faq__item:first-child { border-top: 1px solid rgba(255,255,255,0.08); }
  .faq__item[open] .faq__icon svg { transform: rotate(180deg); }

  .faq__question {
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem; padding: 1.35rem 0; cursor: pointer;
    list-style: none; transition: color var(--ease);
  }
  .faq__question::-webkit-details-marker { display: none; }
  .faq__question:hover .faq__q-text { color: var(--red); }

  .faq__q-text { font-size: 0.92rem; font-weight: 600; color: rgba(255,255,255,0.85); line-height: 1.4; }
  .faq__icon { width: 28px; height: 28px; border: 1px solid rgba(255,255,255,0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .faq__icon svg { width: 14px; height: 14px; stroke: rgba(255,255,255,0.4); transition: transform 0.2s ease; }
  .faq__item[open] .faq__icon { border-color: var(--red); background: rgba(0,247,247,0.07); }
  .faq__item[open] .faq__icon svg { stroke: var(--red); }

  .faq__answer { padding: 0 0 1.25rem; }
  .faq__answer p { font-size: 0.86rem; color: rgba(255,255,255,0.55); line-height: 1.75; max-width: 540px; }

  @media (max-width: 900px) {
    .faq__layout { grid-template-columns: 1fr; gap: 2.5rem; }
    .faq__sidebar { max-width: 480px; }
  }
  @media (max-width: 768px) { .faq { padding: 4rem 0; } }
</style>
