---
const steps = [
  {
    number: "01",
    title: "Pick Your Date & Window",
    desc: "Schedule online or by phone. Choose a 2-hour arrival window that works for your schedule.",
  },
  {
    number: "02",
    title: "We Call 15 Min Ahead",
    desc: "Our crew calls before arrival so you're never waiting around. We show up on time, every time.",
  },
  {
    number: "03",
    title: "Approve Price. We Haul.",
    desc: "Review the upfront quote — no surprise fees. Approve it and we remove your junk on the spot.",
  },
];

const contacts = [
  {
    label: "Book Online",
    badge: "Save $20",
    detail: "Schedule anytime — 24/7 online booking",
    href: "#contact",
    primary: true,
  },
  {
    label: "Call Us",
    badge: null,
    detail: "(561) 246-6352",
    href: "tel:+15612466352",
    primary: false,
  },
  {
    label: "Text Us",
    badge: null,
    detail: "1-737-888-5865",
    href: "sms:17378885865",
    primary: false,
  },
];
---

<section class="how" id="how-it-works">
  <div class="container">

    <div class="tc how__header">
      <span class="eyebrow">Simple Process</span>
      <div class="accent-line"></div>
      <h2 class="h2">How It Works</h2>
      <p class="lead">
        Getting rid of junk has never been easier. Three steps and it's done —
        90% of the time we can take your junk the same day you call.
      </p>
    </div>

    <div class="steps">
      {steps.map((s, i) => (
        <div class="step">
          <span class="step__number">{s.number}</span>
          {i < steps.length - 1 && <span class="step__arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>}
          <h3 class="step__title">{s.title}</h3>
          <p class="step__desc">{s.desc}</p>
        </div>
      ))}
    </div>

    <!-- Same-day callout -->
    <div class="same-day">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
        <circle cx="12" cy="12" r="10"/>
        <path d="M12 8v4l3 3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p><strong>Same-day service available.</strong> 90% of the time we can take your junk immediately after you call.</p>
    </div>

    <!-- Contact methods -->
    <div class="contact-methods">
      {contacts.map((c) => (
        <a href={c.href} class={`contact-card${c.primary ? " contact-card--primary" : ""}`}>
          {c.primary ? (
            <div class="contact-card__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M8 7h8M8 12h5" stroke-linecap="round"/>
              </svg>
            </div>
          ) : c.detail.includes("561") ? (
            <div class="contact-card__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.5 19.79 19.79 0 01.02 2.84 2 2 0 012 .67h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.49a16 16 0 006.29 6.29l1.1-1.1a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
              </svg>
            </div>
          ) : (
            <div class="contact-card__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
              </svg>
            </div>
          )}
          <div class="contact-card__body">
            <span class="contact-card__label">
              {c.label}
              {c.badge && <span class="badge">{c.badge}</span>}
            </span>
            <span class="contact-card__detail">{c.detail}</span>
          </div>
          <svg class="contact-card__arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .how { padding: 6rem 0; background: var(--white); }
  .how__header { margin-bottom: 4rem; }

  /* Steps */
  .steps {
    display: grid; grid-template-columns: repeat(3,1fr);
    gap: 0; position: relative; margin-bottom: 2.5rem;
  }
  .step {
    position: relative; padding: 2.5rem 2rem 2.5rem;
    text-align: center; border: 1px solid var(--ink-200);
    background: var(--white); transition: all var(--ease);
  }
  .step:first-child { border-radius: var(--r-lg) 0 0 var(--r-lg); }
  .step:last-child  { border-radius: 0 var(--r-lg) var(--r-lg) 0; }
  .step + .step     { border-left: none; }
  .step:hover       { background: var(--ink-50); }

  .step__number {
    display: block; font-size: 3rem; font-weight: 900;
    color: var(--red-sub); letter-spacing: -0.04em;
    line-height: 1; margin-bottom: 1.25rem;
    -webkit-text-stroke: 2px var(--red);
  }
  .step__arrow {
    position: absolute; top: 50%; right: -1px;
    transform: translateY(-50%);
    background: var(--white); border: 1px solid var(--ink-200);
    border-radius: 50%; width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    z-index: 1;
  }
  .step__arrow svg { width: 14px; height: 14px; stroke: var(--ink-400); }
  .step__title { font-size: 1rem; font-weight: 700; color: var(--ink-900); margin-bottom: 0.6rem; }
  .step__desc  { font-size: 0.85rem; color: var(--ink-500); line-height: 1.65; }

  /* Same-day */
  .same-day {
    display: flex; align-items: center; gap: 0.85rem;
    background: var(--red-sub); border: 1px solid rgba(200,16,46,0.15);
    border-radius: var(--r-lg); padding: 1rem 1.5rem;
    margin-bottom: 3rem;
  }
  .same-day svg { width: 22px; height: 22px; stroke: var(--red); flex-shrink: 0; }
  .same-day p   { font-size: 0.88rem; color: var(--ink-700); line-height: 1.5; }
  .same-day strong { color: var(--ink-900); }

  /* Contact cards */
  .contact-methods { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 1rem; }
  .contact-card {
    display: flex; align-items: center; gap: 1rem;
    padding: 1.5rem; border-radius: var(--r-lg);
    border: 1px solid var(--ink-200); background: var(--white);
    text-decoration: none; transition: all var(--ease);
  }
  .contact-card:hover { border-color: var(--red); box-shadow: var(--sh-md); transform: translateY(-2px); }
  .contact-card--primary { background: var(--ink-900); border-color: var(--ink-900); }
  .contact-card--primary .contact-card__icon { background: rgba(255,255,255,0.08); }
  .contact-card--primary .contact-card__icon svg { stroke: #fff; }
  .contact-card--primary .contact-card__label { color: #fff; }
  .contact-card--primary .contact-card__detail { color: rgba(255,255,255,0.55); }
  .contact-card--primary .contact-card__arrow { stroke: rgba(255,255,255,0.5); }
  .contact-card--primary:hover .contact-card__arrow { stroke: #fff; }

  .contact-card__icon {
    width: 44px; height: 44px; background: var(--ink-100);
    border-radius: var(--r); display: flex; align-items: center;
    justify-content: center; flex-shrink: 0;
  }
  .contact-card__icon svg { width: 20px; height: 20px; stroke: var(--ink-600); }
  .contact-card__body { flex: 1; }
  .contact-card__label {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.88rem; font-weight: 700; color: var(--ink-900);
    margin-bottom: 0.2rem;
  }
  .contact-card__detail { font-size: 0.82rem; color: var(--ink-500); display: block; }
  .contact-card__arrow { width: 16px; height: 16px; stroke: var(--ink-300); flex-shrink: 0; transition: all var(--ease); }
  .contact-card:hover .contact-card__arrow { stroke: var(--red); transform: translateX(3px); }

  .badge {
    font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.04em; background: var(--red); color: #fff;
    padding: 0.15rem 0.5rem; border-radius: 20px;
  }

  @media (max-width: 900px) {
    .steps { grid-template-columns: 1fr; }
    .step:first-child { border-radius: var(--r-lg) var(--r-lg) 0 0; }
    .step:last-child  { border-radius: 0 0 var(--r-lg) var(--r-lg); }
    .step + .step { border-left: 1px solid var(--ink-200); border-top: none; }
    .step__arrow { display: none; }
    .contact-methods { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .how { padding: 4rem 0; }
  }
</style>
