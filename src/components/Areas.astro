---
const areas = [
  "Boynton Beach",
  "Delray Beach",
  "Greenacres",
  "Lake Worth",
  "Lake Worth Beach",
  "Lantana",
  "Palm Springs",
  "Wellington",
  "West Palm Beach",
  "Jupiter",
  "Palm Beach Gardens",
  "Riviera Beach",
];
---

<section class="areas" id="areas">
  <div class="container">
    <div class="areas-inner">
      <div class="areas-content">
        <span class="section-tag">Service Area</span>
        <h2 class="section-title">We Proudly Serve<br/>Palm Beach County</h2>
        <p class="section-subtitle">
          Junk King Jupiter strives to make your junk removal experience stress-free.
          We serve Palm Beach County and the surrounding regions with fast, reliable service.
        </p>

        <a href="#contact" class="btn btn-primary btn-lg" style="margin-top: 2rem; display: inline-flex;">
          Book in Your Area
        </a>
      </div>

      <div class="areas-grid-wrapper">
        <h3 class="areas-grid-title">Areas We Serve</h3>
        <div class="areas-grid">
          {areas.map((area) => (
            <div class="area-item">
              <span class="area-pin">📍</span>
              <span>{area}</span>
            </div>
          ))}
        </div>

        <div class="hq-card">
          <div class="hq-icon">🏢</div>
          <div class="hq-info">
            <strong>Junk King Jupiter</strong>
            <span>1559 S Cypress Dr, Unit 3</span>
            <span>Jupiter, FL 33469</span>
          </div>
          <a href="tel:5612466352" class="btn btn-primary" style="padding: 0.6rem 1.25rem; font-size: 0.875rem;">
            📞 Call Now
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .areas {
    padding: 6rem 0;
    background: var(--color-white);
  }

  .areas-inner {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 5rem;
    align-items: center;
  }

  .areas-grid-wrapper {
    background: var(--color-gray-50);
    border-radius: var(--border-radius-lg);
    padding: 2.5rem;
    border: 1px solid var(--color-gray-200);
  }

  .areas-grid-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-gray-900);
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--color-primary);
    display: inline-block;
  }

  .areas-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .area-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-gray-700);
    padding: 0.6rem 0.75rem;
    border-radius: var(--border-radius);
    transition: all var(--transition);
    cursor: pointer;
    font-weight: 500;
  }

  .area-item:hover {
    background: rgba(200, 16, 46, 0.06);
    color: var(--color-primary);
  }

  .area-pin {
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  .hq-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--color-white);
    border-radius: var(--border-radius);
    padding: 1.25rem;
    border: 1px solid var(--color-gray-200);
    box-shadow: var(--shadow-sm);
  }

  .hq-icon {
    font-size: 2rem;
    flex-shrink: 0;
  }

  .hq-info {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .hq-info strong {
    font-size: 0.9rem;
    color: var(--color-gray-900);
  }

  .hq-info span {
    font-size: 0.8rem;
    color: var(--color-gray-500);
  }

  @media (max-width: 1024px) {
    .areas-inner {
      gap: 3rem;
    }
  }

  @media (max-width: 768px) {
    .areas {
      padding: 4rem 0;
    }

    .areas-inner {
      grid-template-columns: 1fr;
    }

    .areas-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .hq-card {
      flex-wrap: wrap;
    }
  }
</style>
