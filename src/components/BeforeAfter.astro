---
const projects = [
  {
    title: "Sod Installation",
    location: "Palm Beach County",
    before: "/work-sod-before.jpg",
    after:  "/work-sod-after.jpg",
    tag: "Sod Installation",
  },
  {
    title: "Junk & Debris Removal",
    location: "Palm Beach County",
    before: "/work-junk-before.jpg",
    after:  "/work-junk-after.jpg",
    tag: "Junk Removal",
  },
];
---

<section class="ba" id="work">
  <div class="container">

    <div class="tc ba__header reveal">
      <span class="eyebrow">Our Work</span>
      <div class="accent-line"></div>
      <h2 class="h2">Before &amp; After</h2>
      <p class="lead">Real jobs, real results. See the AMG difference in action.</p>
    </div>

    <div class="ba__grid reveal-group">
      {projects.map((p, i) => (
        <div class="ba__card">
          <div class="ba__tag">{p.tag}</div>

          <div class="ba__slider" data-slider>
            <!-- AFTER (fondo, full width) -->
            <div class="ba__img-wrap ba__img--after">
              <img src={p.after}  alt={`After — ${p.title}`}  loading="lazy" decoding="async" />
              <span class="ba__label ba__label--after">After</span>
            </div>
            <!-- BEFORE (encima, se recorta con clip-path) -->
            <div class="ba__img-wrap ba__img--before">
              <img src={p.before} alt={`Before — ${p.title}`} loading="lazy" decoding="async" />
              <span class="ba__label ba__label--before">Before</span>
            </div>
            <!-- Handle -->
            <div class="ba__handle" aria-hidden="true">
              <div class="ba__handle-line"></div>
              <div class="ba__handle-circle">
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M7 4l-4 6 4 6M13 4l4 6-4 6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="ba__handle-line"></div>
              <div class="ba__hint">
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path d="M4 10h12M4 10l3-3M4 10l3 3M16 10l-3-3M16 10l-3 3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Drag
              </div>
            </div>
          </div>

          <div class="ba__info">
            <strong>{p.title}</strong>
            <span>{p.location}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="tc ba__cta reveal">
      <a href="#contact" class="btn btn-primary btn-lg">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 3.5A1.5 1.5 0 013.5 2h1.148a1 1 0 01.95.684l.93 2.8a1 1 0 01-.23 1.02L5.1 7.7a11.04 11.04 0 005.2 5.2l1.196-1.198a1 1 0 011.02-.23l2.8.93A1 1 0 0116 13.35v1.15A1.5 1.5 0 0114.5 16C7.596 16 2 10.404 2 3.5z"/></svg>
        Get Your Estimate
      </a>
    </div>

  </div>
</section>

<script is:inline>
(function () {
  function initSlider(card) {
    const before = card.querySelector('.ba__img--before');
    const handle = card.querySelector('.ba__handle');
    const hint   = card.querySelector('.ba__hint');
    let pct = 50;
    let dragging = false;
    let hintDone = false;

    function setPos(x) {
      const rect = card.getBoundingClientRect();
      pct = Math.min(100, Math.max(0, ((x - rect.left) / rect.width) * 100));
      before.style.clipPath = `inset(0 ${100 - pct}% 0 0)`;
      handle.style.left = pct + '%';
    }

    function setPct(p) {
      pct = p;
      before.style.clipPath = `inset(0 ${100 - p}% 0 0)`;
      handle.style.left = p + '%';
    }

    // Animación de hint: se mueve derecha → izquierda → centro
    function playHint() {
      if (hintDone) return;
      hintDone = true;
      card.classList.add('ba--hinting');
      // Secuencia: 50% → 72% → 28% → 50%
      const steps = [
        { pct: 72,  delay: 400  },
        { pct: 28,  delay: 900  },
        { pct: 50,  delay: 1500 },
      ];
      steps.forEach(({ pct: p, delay }) => {
        setTimeout(() => setPct(p), delay);
      });
      setTimeout(() => {
        card.classList.remove('ba--hinting');
        if (hint) hint.classList.add('ba__hint--hidden');
      }, 2200);
    }

    setPct(50);

    // Dispara hint cuando la card entra en pantalla
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) { playHint(); obs.unobserve(card); }
      });
    }, { threshold: 0.5 });
    obs.observe(card);

    // Ocultar hint al primer drag/click
    function dismissHint() {
      if (hint && !hint.classList.contains('ba__hint--hidden')) {
        hint.classList.add('ba__hint--hidden');
      }
    }

    handle.addEventListener('mousedown',  e => { dragging = true; e.preventDefault(); dismissHint(); });
    handle.addEventListener('touchstart', e => { dragging = true; dismissHint(); }, { passive: true });
    window.addEventListener('mousemove',  e => { if (dragging) setPos(e.clientX); });
    window.addEventListener('touchmove',  e => { if (dragging) setPos(e.touches[0].clientX); }, { passive: true });
    window.addEventListener('mouseup',  () => dragging = false);
    window.addEventListener('touchend', () => dragging = false);
    card.addEventListener('click', e => { setPos(e.clientX); dismissHint(); });
  }

  document.querySelectorAll('[data-slider]').forEach(initSlider);
})();
</script>

<style>
  .ba { padding: 6rem 0; background: var(--ink-900); }

  .ba__header { margin-bottom: 3.5rem; }

  .ba__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .ba__card {
    border-radius: var(--r-xl);
    overflow: hidden;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    position: relative;
  }

  .ba__tag {
    position: absolute; top: 1rem; left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    background: var(--red);
    color: var(--ink-900);
    font-size: 0.7rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    padding: 0.3rem 0.85rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  /* Slider container */
  .ba__slider {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    cursor: ew-resize;
    user-select: none;
  }

  .ba__img-wrap {
    position: absolute; inset: 0;
  }
  .ba__img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    display: block;
    pointer-events: none;
  }

  /* Before panel recortado */
  .ba__img--before {
    clip-path: inset(0 50% 0 0);
    z-index: 2;
  }

  /* Labels */
  .ba__label {
    position: absolute; bottom: 0.75rem;
    font-size: 0.7rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    padding: 0.25rem 0.7rem;
    border-radius: 100px;
    z-index: 3;
  }
  .ba__label--before {
    left: 0.75rem;
    background: rgba(0,0,0,0.55); color: rgba(255,255,255,0.9);
    backdrop-filter: blur(6px);
  }
  .ba__label--after {
    right: 0.75rem;
    background: var(--red); color: var(--ink-900);
  }

  /* Handle */
  .ba__handle {
    position: absolute; top: 0; bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
    display: flex; flex-direction: column; align-items: center;
    cursor: ew-resize;
    transition: left 0s;
  }
  .ba__handle-line {
    flex: 1; width: 2px;
    background: rgba(255,255,255,0.8);
    backdrop-filter: blur(2px);
  }
  .ba__handle-circle {
    width: 44px; height: 44px; flex-shrink: 0;
    background: #fff;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 12px rgba(0,0,0,0.35);
    transition: transform 0.15s;
  }
  .ba__handle-circle:hover { transform: scale(1.1); }
  .ba__handle-circle svg { width: 18px; height: 18px; stroke: var(--ink-900); }

  /* Hint tooltip */
  .ba__hint {
    position: absolute;
    top: calc(50% + 30px);
    left: 50%; transform: translateX(-50%);
    background: rgba(0,0,0,0.72);
    backdrop-filter: blur(6px);
    color: #fff;
    font-size: 0.68rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    padding: 0.3rem 0.7rem;
    border-radius: 100px;
    white-space: nowrap;
    display: flex; align-items: center; gap: 0.35rem;
    pointer-events: none;
    transition: opacity 0.4s;
    animation: hint-pulse 1.2s ease-in-out infinite;
  }
  .ba__hint svg { width: 14px; height: 14px; flex-shrink: 0; }
  .ba__hint--hidden { opacity: 0 !important; animation: none; }

  /* Animación de pulso del tooltip */
  @keyframes hint-pulse {
    0%, 100% { opacity: 1; transform: translateX(-50%) scale(1); }
    50%       { opacity: 0.7; transform: translateX(-50%) scale(1.05); }
  }

  /* Transición suave del handle durante el hint automático */
  .ba--hinting .ba__handle,
  .ba--hinting .ba__img--before {
    transition: left 0.55s cubic-bezier(0.4,0,0.2,1),
                clip-path 0.55s cubic-bezier(0.4,0,0.2,1);
  }

  .ba__info {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.85rem 1.1rem;
    border-top: 1px solid rgba(255,255,255,0.07);
  }
  .ba__info strong { font-size: 0.85rem; color: #fff; font-weight: 600; }
  .ba__info span   { font-size: 0.75rem; color: rgba(255,255,255,0.35); }

  .ba__cta { margin-top: 1rem; }

  @media (max-width: 768px) {
    .ba { padding: 3.5rem 0; }
    .ba__grid { grid-template-columns: 1fr; gap: 2rem; }
    .ba__handle { width: 44px; height: 44px; }
    .ba__handle svg { width: 20px; height: 20px; }
    .ba__label { padding: 0.25rem 0.6rem; font-size: 0.68rem; }
  }
  @media (max-width: 480px) {
    .ba__slider { aspect-ratio: 4/3; }
    .ba__info { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
  }
</style>
