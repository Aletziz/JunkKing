---
const reviews = [
  {
    name: "Krissy M.",
    initials: "K",
    rating: 5,
    text: "I used them to remove items from a storage unit. The guys worked quick and they had good customer service. Overall, a great experience. They were professional and efficient!",
    color: "#ef4444",
  },
  {
    name: "Jody Prince-Warner",
    initials: "J",
    rating: 5,
    text: "Called Junk King and they came to the house to give an estimate within a half hour. The price was so good I hired them right then and there. They were gone with my junk within an hour. Very nice people… I highly recommend them!",
    color: "#3b82f6",
  },
  {
    name: "Robert T.",
    initials: "R",
    rating: 5,
    text: "Excellent service! They showed up on time, were very courteous and professional. They cleared out my garage in no time and the price was very reasonable. Will definitely use them again.",
    color: "#10b981",
  },
  {
    name: "Maria S.",
    initials: "M",
    rating: 5,
    text: "Super friendly team, very professional. They handled everything quickly and cleaned up after themselves. I appreciated their eco-friendly approach — knowing items get donated or recycled is a huge plus!",
    color: "#f59e0b",
  },
  {
    name: "David L.",
    initials: "D",
    rating: 5,
    text: "Had an old hot tub that needed removal. They came same day, disassembled it carefully, and hauled everything away. Truly king-size service for a reasonable price. Highly recommend!",
    color: "#8b5cf6",
  },
  {
    name: "Sandra B.",
    initials: "S",
    rating: 5,
    text: "From booking to pickup, the experience was seamless. The crew was polite and hard-working. They handled my bulky furniture and appliances without any issues. 5 stars!",
    color: "#ec4899",
  },
];
---

<section class="reviews" id="reviews">
  <div class="container">
    <div class="text-center section-header">
      <span class="section-tag">Customer Reviews</span>
      <h2 class="section-title">What Our Customers Say</h2>
      <div class="review-summary">
        <div class="summary-stars">
          {"★".repeat(5)}
        </div>
        <strong>5/5 Rating</strong>
        <span>·</span>
        <span>983+ Customer Reviews</span>
      </div>
    </div>

    <div class="reviews-grid">
      {reviews.map((review) => (
        <div class="review-card">
          <div class="review-header">
            <div class="reviewer-avatar" style={`background: ${review.color};`}>
              {review.initials}
            </div>
            <div class="reviewer-info">
              <strong class="reviewer-name">{review.name}</strong>
              <div class="reviewer-stars">
                {"★".repeat(review.rating)}
              </div>
            </div>
            <div class="google-badge">G</div>
          </div>
          <p class="review-text">{review.text}</p>
        </div>
      ))}
    </div>

    <div class="text-center" style="margin-top: 3rem;">
      <a href="https://www.junk-king.com/locations/palmbeach/reviews" target="_blank" rel="noopener" class="btn btn-outline">
        View All 983 Reviews →
      </a>
    </div>
  </div>
</section>

<style>
  .reviews {
    padding: 6rem 0;
    background: var(--color-gray-50);
  }

  .section-header {
    margin-bottom: 3.5rem;
  }

  .review-summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
    font-size: 0.95rem;
    color: var(--color-gray-600);
  }

  .summary-stars {
    color: #fbbf24;
    font-size: 1.25rem;
    letter-spacing: 0.05em;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .review-card {
    background: var(--color-white);
    border-radius: var(--border-radius-lg);
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-gray-200);
    transition: all var(--transition);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .review-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .review-header {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .reviewer-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 800;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .reviewer-info {
    flex: 1;
  }

  .reviewer-name {
    display: block;
    font-size: 0.9rem;
    color: var(--color-gray-900);
    margin-bottom: 0.2rem;
  }

  .reviewer-stars {
    color: #fbbf24;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }

  .google-badge {
    width: 28px;
    height: 28px;
    background: linear-gradient(135deg, #4285f4, #34a853, #fbbc04, #ea4335);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 900;
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  .review-text {
    font-size: 0.875rem;
    color: var(--color-gray-600);
    line-height: 1.7;
    font-style: italic;
    flex: 1;
  }

  @media (max-width: 1024px) {
    .reviews-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .reviews {
      padding: 4rem 0;
    }

    .reviews-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
