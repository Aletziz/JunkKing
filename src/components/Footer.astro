  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-brand {
      grid-column: 1;
    }

    .footer-neighborly-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .neighborly-text {
      flex-direction: column;
      align-items: flex-start;
    }

    .app-download {
